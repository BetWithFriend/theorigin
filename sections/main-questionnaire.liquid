              type="hidden"
              name="id"
              id="q-footer-variant-id"
              value="">
            <button
              type="submit"
              name="add"
              id="q-footer-atc-btn"
              class="questionnaire-add-btn">
              <span id="q-footer-atc-label">קנייה מהירה</span>
            </button>
          </form>
        </div>
