      <div class="questionnaire-checkout-section">
        <div class="questionnaire-price-wrapper">
          <div class="price-label-group">
            <span class="price-label-main">סה״כ לתשלום</span>
            <span class="price-label-sub">(כולל משלוח)</span>
          </div>
          <div class="price-values-group">
            <span class="price-current" id="q-footer-price"></span>
            <span class="price-compare" id="q-footer-price-compare"></span>
          </div>
        </div>

        <div class="questionnaire-add-to-cart-wrapper">
