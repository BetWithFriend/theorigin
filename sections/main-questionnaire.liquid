  <div class="questionnaire-icons-wrapper" id="questionnaireResultsStep">
    <header class="questionnaire-header questionnaire-header--results" role="banner">
      <div class="questionnaire-header__start">
        <div class="questionnaire-logo">
          <img
            src="{{ 'logo.png' | asset_url }}"
            alt="{{ shop.name }}"
            width="88"
            height="auto">
        </div>
      </div>
      <div class="questionnaire-header__center">
        <div
          class="results-header-bundle"
          role="group"
          aria-label="תצוגת מארז">
          <button
            type="button"
            id="q-bundle-view-toggle"
            class="results-bundle-view-toggle"
            aria-expanded="false"
            aria-controls="q-bundle-view-table">
            <span class="results-bundle-view-toggle__stack">
              {% comment %} <span class="results-bundle-view-toggle__title">המארז שלך</span> {% endcomment %}
              <span id="q-bundle-view-toggle-sublabel" class="results-bundle-view-toggle__sublabel">הצג הכל בטבלה</span>
            </span>
            <svg
              class="results-bundle-view-toggle__chev"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true">
              <path
                d="M4 6H20M4 12H20M4 18H20"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round" />
            </svg>
          </button>
        {% comment %} <span class="results-title-counter" id="q-carousel-counter">(1/5)</span> {% endcomment %}
