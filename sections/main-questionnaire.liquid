            </div>
          </div>

          <button
            class="q-carousel-arrow q-carousel-arrow--next"
            id="qCarouselNext"
            aria-label="הבא"
            type="button">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg">
              <path
                d="M9 18L15 12L9 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
