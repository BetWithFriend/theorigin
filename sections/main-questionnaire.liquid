    }
    const rows = pickKeys.map((vendorKey) => {
      const orderScore = (positiveScores || []).reduce(function (s, item) {
        if ((item.coffee.vendor || '').trim().toLowerCase() === vendorKey) return s + (item.score || 0);
        return s;
      }, 0);
      return {
        vendorKey: vendorKey,
        label: getVendorDisplayNameFromPool(vendorKey, positiveScores) || vendorKey,
        orderScore: orderScore,
      };
    });
    return sortVendorOptionsByMatchDesc(rows);
  }

  function matchQuestionnaireCoffees(userText) {
    const catalog = ensureAllProductsLoaded();
    if (!catalog.length) {
      return [];
    }

    const S = window.QuestionnaireScoring;
    const params = window.__questionnaireParams;

    const WEIGHTS = {
      guidedPrepPerMatch: 1,
      guidedRoastPerMatch: 3,
      guidedTastePerMatch: 5,
    };
    const THRESHOLDS = {
      minProductScore: 0,
      minBundleScore: { 3: 20, 5: 35, 7: 53 },
    };

    function getCoffeeProcessValue(product) {
      const raw = product && product.metafields ? product.metafields.coffee_process : null;
      if (raw && typeof raw === 'object' && raw !== null && raw.value != null) return String(raw.value);
      return String(raw || '');
    }

    function isDecaf(product) {
      const process = getCoffeeProcessValue(product);
      const tags = Array.isArray(product && product.tags) ? product.tags.join(' ') : '';
      const text = [
        product && product.handle,
        product && product.title,
        product && product.short_description,
        process,
        tags,
      ].filter(Boolean).join(' ').toLowerCase();
      return (
        text.indexOf('decaf') !== -1 ||
        text.indexOf('d-caf') !== -1 ||
        text.indexOf('נטול') !== -1 ||
        text.indexOf('נטולת') !== -1 ||
        text.indexOf('ללא קפאין') !== -1
      );
    }

    const coffeeDatabase = catalog.map(function (product) {
      const mf = product.metafields || {};
      const roastRaw = mf.coffee_roast_level;
      const coffeeRoastLevel =
        roastRaw && typeof roastRaw === 'object' && roastRaw !== null && roastRaw.value != null
          ? String(roastRaw.value)
          : String(roastRaw || '');
      return Object.assign({}, product, {
        prep_method: normalizeMetaList(mf.coffee_prep_methods),
        tastes: normalizeProductTasteKeys(mf),
        coffee_roast_level: coffeeRoastLevel,
      });
    }).filter(function (product) {
      return !isDecaf(product);
    });

    let withScores;
    let matchShowAll = false;
    const selectedBundleQty = getQuestionnaireResultsBundleQty();

    if (S && params) {
      const matchResult = S.matchCoffees(params, coffeeDatabase, WEIGHTS, THRESHOLDS);
      withScores = matchResult.withScores || [];
      matchShowAll = !!matchResult.showAll;
    } else {
      const text = (userText || '').toLowerCase();
      withScores = coffeeDatabase.map(function (coffee) {
        let score = 0;
        (coffee.prep_method || []).forEach(function (m) { if (text.includes(m.toLowerCase())) score += 1; });
        (coffee.tastes || []).forEach(function (t) { if (text.includes(t.toLowerCase())) score += 5; });
        return { coffee: coffee, score: score, roastMeta: { type: null, selected: null, product: coffee.coffee_roast_level || '' } };
      }).filter(function (x) { return x.score > 0; }).sort(function (a, b) { return b.score - a.score; });
    }

    window.__questionnaireLastWithScores = withScores;
    window.__questionnaireLastPositiveScores = withScores;

    let bundleResult = null;
    if (S && withScores.length > 0) {
      bundleResult = S.buildVendorBundles(withScores, THRESHOLDS, {
        showAll: matchShowAll,
        selectedRoastLevels: params ? S.expandRoastLevelsForMatching(params.roast_levels || []) : [],
      });
      window.__questionnaireBundleResult = bundleResult;
    }

    const currentUserText = window.__questionnaireMatchUserText || userText || '';
    const previousAssignedQty = window.__questionnaireVendorAssignmentForQty;
    const qtyChanged = previousAssignedQty !== selectedBundleQty;
    const sameQuestionnaireText = window.__questionnaireVendorAssignmentForText === currentUserText;
    if (!sameQuestionnaireText || !window.__questionnaireVendorOptionsByQty || typeof window.__questionnaireVendorOptionsByQty !== 'object') {
      window.__questionnaireVendorOptionsByQty = {};
    }
    if (!window.__questionnaireSelectedVendorByQty || typeof window.__questionnaireSelectedVendorByQty !== 'object') {
      window.__questionnaireSelectedVendorByQty = {};
    }
    const needsNewVendorOptions =
      !window.__questionnaireVendorOptions ||
      !window.__questionnaireVendorOptions.length ||
      window.__questionnaireVendorAssignmentForText !== currentUserText ||
      qtyChanged;

    if (needsNewVendorOptions) {
      const cachedForQty = sameQuestionnaireText
        ? window.__questionnaireVendorOptionsByQty[selectedBundleQty]
        : null;
      let vendorOptions = Array.isArray(cachedForQty) ? cachedForQty.slice() : [];
      if (!vendorOptions.length) {
        if (bundleResult && bundleResult.ok && bundleResult.meta && bundleResult.meta.topVendors) {
            const primary = bundleResult.meta.topVendors[selectedBundleQty] || [];
            vendorOptions = primary.map(function (v) {
              return {
                vendorKey: (v.vendor || '').toLowerCase(),
                label: getVendorDisplayNameFromPool((v.vendor || '').toLowerCase(), withScores) || v.vendor || '',
                orderScore: v.bundleScore || 0,
              };
            }).filter(function (o) { return o.vendorKey; });
        }
        if (!vendorOptions.length) {
          const uniqueVendors = [];
          const seen = {};
          withScores.forEach(function (x) {
            const vk = (x.coffee.vendor || '').trim().toLowerCase();
            if (vk && !seen[vk]) { seen[vk] = true; uniqueVendors.push(vk); }
          });
          vendorOptions = pickThreeVendorOptionsForResults(uniqueVendors, withScores);
        }
        window.__questionnaireVendorOptionsByQty[selectedBundleQty] = vendorOptions.slice();
      }
      window.__questionnaireVendorOptions = vendorOptions;
      window.__questionnaireVendorAssignmentForText = currentUserText;
      window.__questionnaireVendorAssignmentForQty = selectedBundleQty;
      // Keep simulator behavior: when package size changes, move to the top
      // vendor for that size instead of preserving an older vendor selection.
      if (qtyChanged && vendorOptions.length) {
        const selectedForQty = String(window.__questionnaireSelectedVendorByQty[selectedBundleQty] || '').toLowerCase();
        const existsForQty = vendorOptions.some(function (o) {
          return String(o.vendorKey || '').toLowerCase() === selectedForQty;
        });
        window.__questionnaireSelectedVendor = existsForQty ? selectedForQty : vendorOptions[0].vendorKey;
      }
    }

    if (window.__questionnaireSelectedVendor && window.__questionnaireVendorOptions && window.__questionnaireVendorOptions.length) {
      const want = (window.__questionnaireSelectedVendor || '').toLowerCase();
      const inList = window.__questionnaireVendorOptions.some(function (o) {
        return (o.vendorKey || '').toLowerCase() === want;
      });
      const vendorInScores = withScores.some(function (x) { return (x.coffee.vendor || '').trim().toLowerCase() === want; });
      if (!inList && vendorInScores) {
        const name = getVendorDisplayNameFromPool(want, withScores) || want;
        const injectScore = withScores.reduce(function (s, item) {
          return (item.coffee.vendor || '').trim().toLowerCase() === want ? s + (item.score || 0) : s;
        }, 0);
        window.__questionnaireVendorOptions[0] = { vendorKey: want, label: name, orderScore: Math.max(injectScore, 1) };
        window.__questionnaireVendorOptions = sortVendorOptionsByMatchDesc(window.__questionnaireVendorOptions);
        window.__questionnaireVendorOptionsByQty[selectedBundleQty] = window.__questionnaireVendorOptions.slice();
      }
    }

    if (!window.__questionnaireVendorOptions || !window.__questionnaireVendorOptions.length) {
      return [];
    }

    const optionKeys = window.__questionnaireVendorOptions.map(function (o) {
      return (o.vendorKey || '').toLowerCase();
    });
    var sel = (window.__questionnaireSelectedVendor || '').toLowerCase();
    if (!sel || optionKeys.indexOf(sel) === -1) {
      window.__questionnaireSelectedVendor = window.__questionnaireVendorOptions[0].vendorKey;
    }
    window.__questionnaireSelectedVendorByQty[selectedBundleQty] = window.__questionnaireSelectedVendor;

    const targetVendor = (window.__questionnaireSelectedVendor || '').toLowerCase();
    if (!targetVendor) return [];

    if (bundleResult && bundleResult.ok && bundleResult.meta && bundleResult.meta.topVendors && bundleResult.bundles) {
      const topForSize = bundleResult.meta.topVendors[selectedBundleQty] || [];
      const optionIdx = topForSize.findIndex(function (tv) {
        return ((tv && tv.vendor) || '').trim().toLowerCase() === targetVendor;
      });
      const bundleOptions = bundleResult.bundles[selectedBundleQty] || [];
      if (optionIdx >= 0 && Array.isArray(bundleOptions[optionIdx]) && bundleOptions[optionIdx].length) {
        return bundleOptions[optionIdx].slice(0, 7);
      }
    }

    const forVendor = withScores
      .filter(function (item) {
        return (item.coffee.vendor || '').trim().toLowerCase() === targetVendor;
      })
      .sort(function (a, b) {
        const rpa = a.roastMeta && a.roastMeta.type === 'exact' ? 2 : a.roastMeta && a.roastMeta.type === 'partial' ? 1 : 0;
        const rpb = b.roastMeta && b.roastMeta.type === 'exact' ? 2 : b.roastMeta && b.roastMeta.type === 'partial' ? 1 : 0;
        if (rpb !== rpa) return rpb - rpa;
        return b.score - a.score;
      });

    return forVendor.map(function (item) { return item.coffee; }).slice(0, 7);
  }

  function formatQuestionnaireBundleWeightKg(grams) {
    if (grams == null || grams <= 0) return '';
    var kg = grams / 1000;
    var s = kg.toFixed(3).replace(/\.?0+$/, '');
    return s + ' ק"ג';
  }

  function formatQuestionnaireProductWeight(grams) {
    if (grams == null || grams <= 0) return '—';
    if (grams >= 1000) return formatQuestionnaireBundleWeightKg(grams);
    return Math.round(grams) + ' גרם';
  }

  function formatQuestionnaireMoney(cents) {
    return '\u20AA' + (cents / 100).toFixed(0);
  }

  function updateQuestionnaireQtyOptionWeights() {
    var ut = window.__questionnaireMatchUserText;
    var wrapper = document.querySelector('.questionnaire-qty-selector-wrapper');
    if (!wrapper) return;
    wrapper.querySelectorAll('.qty-option').forEach(function (btn) {
      var wEl = btn.querySelector('.qty-option__weight');
      if (!wEl) return;
      var dq = btn.getAttribute('data-qty');
      var q = dq ? parseInt(dq, 10) : 0;
      if (typeof ut !== 'string' || !q) {
        wEl.textContent = '';
        return;
      }
      var prods = matchQuestionnaireCoffees(ut);
      var grams = 0;
      prods.slice(0, q).forEach(function (p) {
        grams += p.weight_grams || 0;
      });
      var w = formatQuestionnaireBundleWeightKg(grams);
      wEl.textContent = w ? w : '';
    });
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function setResultsVendorMenuOpen(isOpen) {
    var drop = document.getElementById('q-results-vendor-dropdown');
    var panel = document.getElementById('q-results-vendor-panel');
    var tr = document.getElementById('q-results-vendor-trigger');
    if (!drop || !panel || !tr) return;
    if (isOpen) {
      drop.setAttribute('data-open', 'true');
      panel.removeAttribute('hidden');
      tr.setAttribute('aria-expanded', 'true');
    } else {
      drop.setAttribute('data-open', 'false');
      panel.setAttribute('hidden', 'hidden');
      tr.setAttribute('aria-expanded', 'false');
    }
  }

  function updateResultsVendorSelect() {
    var list = document.getElementById('q-results-vendor-list');
    if (!list) return;
    var menu = document.getElementById('q-results-vendor-menu');
    var drop = document.getElementById('q-results-vendor-dropdown');
    var tr = document.getElementById('q-results-vendor-trigger');
    var trLabel = document.getElementById('q-results-vendor-trigger-label');
    var opts = window.__questionnaireVendorOptions;

    setResultsVendorMenuOpen(false);

    if (!Array.isArray(opts) || !opts.length) {
      list.innerHTML = '<p class="results-vendor-menu__empty" role="status">' + escapeHtml('אין מותגים להצגה') + '</p>';
      if (menu) menu.setAttribute('data-empty', 'true');
      if (drop) drop.setAttribute('data-empty', 'true');
      if (tr) {
        tr.disabled = true;
        tr.setAttribute('aria-disabled', 'true');
      }
      if (trLabel) trLabel.textContent = 'אין מותגים להצגה';
      var trWeight = document.getElementById('q-results-vendor-trigger-weight');
      if (trWeight) {
        trWeight.textContent = '';
        trWeight.hidden = true;
      }
      var trPrice = document.getElementById('q-results-vendor-trigger-price');
      if (trPrice) {
        trPrice.textContent = '';
        trPrice.hidden = true;
      }
      var trSep = document.getElementById('q-results-vendor-trigger-sep');
      if (trSep) {
        trSep.hidden = true;
      }
      return;
    }
    if (menu) menu.setAttribute('data-empty', 'false');
    if (drop) drop.setAttribute('data-empty', 'false');
    if (tr) {
      tr.disabled = false;
      tr.removeAttribute('aria-disabled');
    }
    var optionKeys = opts.map(function (o) {
      return (o.vendorKey || '').toLowerCase();
    });
    var cur = (window.__questionnaireSelectedVendor || '').toLowerCase();
    if (optionKeys.indexOf(cur) === -1) {
      window.__questionnaireSelectedVendor = opts[0].vendorKey;
    }
    cur = (window.__questionnaireSelectedVendor || '').toLowerCase();
    var currentOpt = opts.find(function (o) {
      return (o.vendorKey || '').toLowerCase() === cur;
    });
    if (trLabel && currentOpt) {
      var tl = currentOpt.label || currentOpt.vendorKey;
      trLabel.textContent = 'מארז מבית הקלייה ' + tl;
    } else if (trLabel) {
      trLabel.textContent = '—';
    }
    var posScores = window.__questionnaireLastPositiveScores;
    if (!Array.isArray(posScores)) posScores = [];
    var menuQty = getQuestionnaireResultsBundleQty();
    var bundleResult = window.__questionnaireBundleResult;
    var topForQty =
      bundleResult && bundleResult.ok && bundleResult.meta && bundleResult.meta.topVendors
        ? bundleResult.meta.topVendors[menuQty] || []
        : [];
    var bundleOptionsForQty =
      bundleResult && bundleResult.ok && bundleResult.bundles
        ? bundleResult.bundles[menuQty] || []
        : [];
    var sepSvg =
      '<svg class="results-vendor-trigger__sep-icon" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg"><circle cx="5" cy="5" r="3.5" fill="currentColor"/></svg>';
    list.innerHTML = opts
      .map(function (o) {
        var v = o.vendorKey || '';
        var vLower = (v || '').toLowerCase();
        var label = o.label || v;
        var bundleIdx = topForQty.findIndex(function (tv) {
          return ((tv && tv.vendor) || '').trim().toLowerCase() === vLower;
        });
        var bundleProds = bundleIdx >= 0 && Array.isArray(bundleOptionsForQty[bundleIdx])
          ? bundleOptionsForQty[bundleIdx].slice(0, menuQty)
          : coffeesForVendorFromPositiveScores(posScores, vLower).slice(0, menuQty);
        var totalWeightGrams = 0;
        bundleProds.forEach(function (p) {
          totalWeightGrams += p.weight_grams || 0;
        });
        var weightInner =
          totalWeightGrams > 0 ? formatQuestionnaireBundleWeightKg(totalWeightGrams) : '';
        var totalCents = bundleTotalWithShippingCentsForQuestionnaireProducts(bundleProds, menuQty, vLower);
        var priceStr = formatQuestionnaireMoney(totalCents);
        var selected = vLower === cur;
        var suffixHtml =
          '<span class="results-vendor-trigger__suffix">' +
          '<span class="results-vendor-trigger__price">' +
          escapeHtml(priceStr) +
          '</span>' +
          (weightInner
            ? '<span class="results-vendor-trigger__sep" aria-hidden="true">' +
              sepSvg +
              '</span>' +
              '<span class="results-vendor-trigger__weight">' +
              escapeHtml(weightInner) +
              '</span>'
            : '') +
          '</span>';
        return (
          '<button type="button" class="results-vendor-menu__item' +
          (selected ? ' is-selected' : '') +
          '" role="option" data-vendor="' +
          escapeHtml(String(v)) +
          '" aria-selected="' +
          (selected ? 'true' : 'false') +
          '"><span class="results-vendor-menu__name">' +
          escapeHtml(label) +
          '</span>' +
          suffixHtml +
          '</button>'
        );
      })
      .join('');
  }

  function setupResultsVendorSelect() {
    var list = document.getElementById('q-results-vendor-list');
    var drop = document.getElementById('q-results-vendor-dropdown');
    var tr = document.getElementById('q-results-vendor-trigger');
    if (!list || !drop || !tr || list._qVendorSelectBound) return;
    list._qVendorSelectBound = true;
    tr.addEventListener('click', function (e) {
      e.stopPropagation();
      if (tr.disabled) return;
      var panel = document.getElementById('q-results-vendor-panel');
      if (!panel) return;
      setResultsVendorMenuOpen(!!panel.hidden);
    });
    list.addEventListener('click', function (e) {
      e.stopPropagation();
      var btn = e.target.closest('.results-vendor-menu__item');
      if (!btn) return;
      var raw = (btn.getAttribute('data-vendor') || '').trim();
      if (!raw) return;
      window.__questionnaireSelectedVendor = raw.toLowerCase();
      if (!window.__questionnaireSelectedVendorByQty || typeof window.__questionnaireSelectedVendorByQty !== 'object') {
        window.__questionnaireSelectedVendorByQty = {};
      }
      window.__questionnaireSelectedVendorByQty[getQuestionnaireResultsBundleQty()] = window.__questionnaireSelectedVendor;
      setResultsVendorMenuOpen(false);
      var ut = window.__questionnaireMatchUserText;
      if (typeof ut !== 'string' || !ut.length) return;
      var next = matchQuestionnaireCoffees(ut);
      var vendorQty = getQuestionnaireResultsBundleQty();
      trackQuestionnaireAnalyticsClick('Quiz - Choose vendor', {
        'Vendor Chosen': getQuestionnaireVendorDisplayName(raw),
        Price: formatQuestionnaireMoney(bundleTotalWithShippingCentsForQuestionnaireProducts(next, vendorQty)),
        'Bundle size': vendorQty,
      });
      saveResultsState(next);
      renderQuestionnaireResults(next);
    });
    if (!window._qVendorMenuOutsideClick) {
      window._qVendorMenuOutsideClick = true;
      document.addEventListener(
        'click',
        function (e) {
          if (!e.target || !e.target.closest) return;
          if (e.target.closest('.results-vendor-dropdown')) return;
          setResultsVendorMenuOpen(false);
        },
        true
      );
      document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape') return;
        if (!document.getElementById('q-results-vendor-dropdown') || !document.getElementById('q-results-vendor-panel')) return;
        if (document.getElementById('q-results-vendor-panel').getAttribute('hidden') != null) return;
        setResultsVendorMenuOpen(false);
        var t = document.getElementById('q-results-vendor-trigger');
        if (t) t.focus();
      });
    }
  }

  function normalizeMetaList(val) {
    if (val == null || val === '') return [];
    if (Array.isArray(val)) return val.filter(Boolean).map(String);
    if (typeof val === 'string') return [val];
    if (typeof val === 'object') {
      if (Array.isArray(val.value)) return val.value.map(String).filter(Boolean);
      if (val.value != null && val.value !== '') return [String(val.value)];
    }
    return [String(val)];
  }

  // Keep taste normalization aligned with the simulator scoring model.
  const CANONICAL_TASTE_KEYS = ['Chocolate', 'Sweet-Chocolate', 'Sweet', 'Fruity-Sweet', 'Fruity'];
  const HEBREW_TO_ENGLISH_TASTE = {
    'שוקולד': 'Chocolate',
    'מתוק-שוקולדי': 'Sweet-Chocolate',
    'מתוק': 'Sweet',
    'פירותי-מתוק': 'Fruity-Sweet',
    'פירותי': 'Fruity',
  };

  function normalizeProductTasteKeys(mf) {
    const fromProfile = normalizeMetaList(mf && mf.coffee_taste);
    const fromLabels = normalizeMetaList(mf && mf.coffee_tastes).map(function (raw) {
      const key = String(raw || '').trim();
      return HEBREW_TO_ENGLISH_TASTE[key] || key;
    });
    const seen = {};
    return fromProfile
      .concat(fromLabels)
      .map(function (raw) { return String(raw || '').trim(); })
      .filter(function (key) {
        if (!key || CANONICAL_TASTE_KEYS.indexOf(key) === -1) return false;
        if (seen[key]) return false;
        seen[key] = true;
        return true;
      });
  }

  /** Matches snippets/product-taste-icon-color.liquid (carousel / bundle card overlay). */
  var Q_TASTE_PROFILE_BADGES = {
    Fruity: { className: 'fruity', label: 'פירותי' },
    Chocolate: { className: 'chocolate', label: 'שוקולדי' },
    'Sweet-Chocolate': { className: 'sweet-chocolate', label: 'מתוק שוקולדי' },
    Sweet: { className: 'sweet-balanced', label: 'מתוק מאוזן' },
    'Fruity-Sweet': { className: 'sweet-fruity', label: 'פירותי מתוק' },
  };

  function buildQuestionnaireTasteProfileIconsHtml(product, forTable) {
    if (!product) return '';
    var mf = product.metafields || {};
    var keys = normalizeMetaList(mf.coffee_taste);
    var parts = [];
    keys.forEach(function (raw) {
      var key = String(raw).trim();
      var spec = Q_TASTE_PROFILE_BADGES[key];
      if (!spec) return;
      parts.push(
        '<span class="' +
          spec.className +
          '">' +
          spec.label +
          '</span>'
      );
    });
    if (!parts.length) return '';
    return (
      '<div class="product-taste-icons questionnaire-product-taste-icons' +
      (forTable ? ' q-bundle-table__taste-icons' : '') +
      '">' +
      '<div class="selection-wrapper plp-taste-text-wrapper">' +
      parts.join('') +
      '</div></div>'
    );
  }

  function buildBundleTableTasteProfileIconsHtml(product) {
    return buildQuestionnaireTasteProfileIconsHtml(product, true);
  }

  var Q_PRODUCT_CARD_HINT_SVG =
    '<svg class="questionnaire-product-title__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" focusable="false">' +
    '<circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.75" />' +
    '<path d="M8.5 11h5M11 8.5v5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />' +
    '<path d="M16.2 16.2 21 21" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />' +
    '</svg>';

  function buildQuestionnaireProductCardHtml(product) {
    if (!product) return '';
    var title = escapeHtml((product.title || '').trim());
    var image = escapeHtml(product.image || '');
    var tasteIcons = buildQuestionnaireTasteProfileIconsHtml(product, false);
    return (
      '<div class="questionnaire-product-card">' +
      '<div class="questionnaire-product-image-wrapper">' +
      (image
        ? '<img src="' +
          image +
          '" alt="' +
          title +
          '" class="questionnaire-product-image" loading="lazy" width="533" height="533">'
        : '') +
      tasteIcons +
      '<div class="questionnaire-product-info">' +
      '<h3 class="questionnaire-product-title">' +
      '<span class="questionnaire-product-title__text">' +
      title +
      '</span>' +
      '<span class="questionnaire-product-title__hint" aria-hidden="true">' +
      Q_PRODUCT_CARD_HINT_SVG +
      '</span>' +
      '</h3>' +
      '</div>' +
      '</div>' +
      '</div>'
    );
  }

  function getBundleTableRoastDisplay(mf) {
    if (!mf) return '';
    var r = mf.coffee_roast_level;
    if (r == null || r === '') return '';
    if (typeof r === 'object' && r !== null && r.value != null && r.value !== '') {
      return String(r.value);
    }
    return String(r);
  }

  function highlightBundleTableRow(index) {
    if (!window.matchMedia('(min-width: 990px)').matches) return;
    var tbody = document.getElementById('q-bundle-table-body');
    if (!tbody) return;
    tbody.querySelectorAll('.q-bundle-table__row').forEach(function (row, rowIndex) {
      row.classList.toggle('is-selected', rowIndex === index);
    });
  }

  var _qBundleTableClickBound = false;

  function setupBundleTableRowActivation() {
    var tbody = document.getElementById('q-bundle-table-body');
    if (!tbody || _qBundleTableClickBound) return;
    _qBundleTableClickBound = true;
    tbody.addEventListener('click', function (e) {
      var row = e.target.closest('.q-bundle-table__row');
      if (!row) return;
      var pool = window.__qResultsShownProducts;
      if (!Array.isArray(pool)) return;
      var pid = row.getAttribute('data-product-id');
      if (!pid) return;
      var found = pool.find(function (p) {
        return p && String(p.id) === String(pid);
      });
      if (!found) return;

      if (window.matchMedia('(min-width: 990px)').matches) {
        var index = pool.findIndex(function (p) {
          return p && String(p.id) === String(pid);
        });
        if (index >= 0 && typeof window.__qCarouselSelectProductIndex === 'function') {
          window.__qCarouselSelectProductIndex(index);
        }
        openQuestionnaireProductModal(found);
        return;
      }

      openQuestionnaireProductModal(found);
    });
  }

  function renderBundleTableFromProducts(shownProducts) {
    var tbody = document.getElementById('q-bundle-table-body');
    if (!tbody) return;
    window.__qResultsShownProducts = shownProducts;
    setupBundleTableRowActivation();
    if (!shownProducts || !shownProducts.length) {
      tbody.innerHTML =
        '<tr><td colspan="3" class="q-bundle-table__empty">אין מוצרים להצגה</td></tr>';
      return;
    }
    tbody.innerHTML = shownProducts
      .map(function (p) {
        var merged = mergeProductFromCatalog(p) || p;
        var title = escapeHtml((merged.title || '').trim() || '—');
        var imgUrl = merged.image ? escapeHtml(merged.image) : '';
        var thumb = imgUrl
          ? '<img class="q-bundle-table__thumb-img" src="' +
            imgUrl +
            '" alt="" loading="lazy" width="44" height="44">'
          : '<span class="q-bundle-table__thumb-fallback" aria-hidden="true"></span>';
        var mf = merged.metafields || {};
        var tasteIcons = buildBundleTableTasteProfileIconsHtml(merged);
        var tasteCell = tasteIcons || '—';
        var roastRaw = getBundleTableRoastDisplay(mf);
        var roastCell = roastRaw ? 'קלייה ' + escapeHtml(roastRaw) : '—';
        return (
          '<tr class="q-bundle-table__row" data-product-id="' +
          escapeHtml(String(merged.id)) +
          '">' +
          '<td class="q-bundle-table__td q-bundle-table__td--roast">' +
          roastCell +
          '</td>' +
          '<td class="q-bundle-table__td q-bundle-table__td--taste">' +
          tasteCell +
          '</td>' +
          '<td class="q-bundle-table__td q-bundle-table__td--product"><div class="q-bundle-table__product">' +
          '<span class="q-bundle-table__title">' +
          title +
          '</span>' +
          thumb +
          '</div></td>' +
          '</tr>'
        );
      })
      .join('');
  }

  function setResultsBundleView(useTable) {
    var step = document.getElementById('questionnaireResultsStep');
    var carouselView = document.getElementById('q-bundle-view-carousel');
    var tableView = document.getElementById('q-bundle-view-table');
    var btn = document.getElementById('q-results-view-toggle');
    if (!step || !carouselView || !tableView) return;
    if (useTable) {
      step.classList.add('results-step--table-view');
      carouselView.hidden = true;
      tableView.hidden = false;
    } else {
      step.classList.remove('results-step--table-view');
      carouselView.hidden = false;
      tableView.hidden = true;
    }
    if (btn) {
      btn.setAttribute('aria-pressed', useTable ? 'true' : 'false');
      btn.setAttribute('aria-label', useTable ? 'הצג תצוגת קרוסלה' : 'הצג תצוגת טבלה');
      btn.setAttribute('title', useTable ? 'תצוגת קרוסלה' : 'תצוגת טבלה');
    }
  }

  function resetBundleViewToCarousel() {
    setResultsBundleView(false);
  }

  var _qResultsViewToggleBound = false;

  function setupResultsViewToggle() {
    var btn = document.getElementById('q-results-view-toggle');
    if (!btn || _qResultsViewToggleBound) return;
    _qResultsViewToggleBound = true;
    btn.addEventListener('click', function () {
      var step = document.getElementById('questionnaireResultsStep');
      var isTable = step && step.classList.contains('results-step--table-view');
      var willShowTable = !isTable;
      setResultsBundleView(willShowTable);
      trackQuestionnaireAnalyticsClick('Quiz - Tabular', {
        'View Type': willShowTable ? 'Show Tabular' : 'Show Normal',
      });
    });
  }

  function mergeProductFromCatalog(product) {
    if (!product) return product;
    const catalog = ensureAllProductsLoaded();
    if (!catalog.length) return product;
    const full = catalog.find(function (p) {
      return String(p.id) === String(product.id);
    });
    /* Session/saved hits may omit fields; overlay catalog row so description/url/metafields resolve. */
    return full ? Object.assign({}, product, full) : product;
  }

  function openQuestionnaireProductModal(product) {
    const merged = mergeProductFromCatalog(product);
    if (!merged) return;

    trackQuestionnaireAnalyticsClick('Quiz - Product Clicked', {
      'Product name': (merged.title || '').trim(),
      'Product vendor': (merged.vendor || '').trim(),
    });

    const modal = document.getElementById('q-product-detail-modal');
    if (!modal) return;

    const img = document.getElementById('q-product-modal-image');
    const titleEl = document.getElementById('q-product-modal-title');
    const vendorEl = document.getElementById('q-product-modal-vendor');
    const chipsEl = document.getElementById('q-product-modal-chips');
    const shortEl = document.getElementById('q-product-modal-short');
    // const descBlock = document.getElementById('q-product-modal-description-block');
    const descEl = document.getElementById('q-product-modal-description');
    const priceEl = document.getElementById('q-product-modal-price');
    const variantInput = document.getElementById('q-product-modal-variant-id');
    const atcBtn = document.getElementById('q-product-modal-atc-btn');
    const atcLabel = document.getElementById('q-product-modal-atc-label');
    const pdpLink = document.getElementById('q-product-modal-pdp-link');

    if (img) {
      img.src = merged.image || '';
      img.alt = merged.title || '';
    }
    if (titleEl) titleEl.textContent = merged.title || '';
    if (vendorEl) {
      vendorEl.textContent = merged.vendor || '';
      vendorEl.style.display = merged.vendor ? '' : 'none';
    }

    const shortDesc = (merged.short_description || '').trim();
    if (shortEl) {
      shortEl.textContent = shortDesc;
      shortEl.hidden = !shortDesc;
    }

    if (priceEl) priceEl.textContent = merged.price || '';

    const mf = merged.metafields || {};
    const roast = mf.coffee_roast_level;
    const prep = normalizeMetaList(mf.coffee_prep_methods);
    const tastes = normalizeMetaList(mf.coffee_tastes);

    if (chipsEl) {
      const sections = [];
      if (roast) {
        sections.push({ label: 'רמת קלייה', items: [String(roast)] });
      }
      // if (prep.length) sections.push({ label: 'שיטת הכנה', items: prep });
      if (tastes.length) sections.push({ label: 'פרופיל טעם', items: tastes });

      if (sections.length === 0) {
        chipsEl.innerHTML = '';
        chipsEl.hidden = true;
      } else {
        chipsEl.hidden = false;
        chipsEl.innerHTML = sections
          .map(function (sec) {
            const chips = sec.items
              .map(function (t) {
                return '<span class="q-product-modal__chip">' + escapeHtml(t) + '</span>';
              })
              .join('');
            return (
              '<div class="q-product-modal__chip-group">' +
              '<span class="q-product-modal__chip-label">' +
              escapeHtml(sec.label) +
              '</span>' +
              '<div class="q-product-modal__chip-row">' +
              chips +
              '</div></div>'
            );
          })
          .join('');
      }
    }

    if (variantInput) variantInput.value = merged.variantId || '';
    if (atcBtn && atcLabel) {
      if (merged.available) {
        atcBtn.disabled = false;
        atcLabel.textContent = 'הוספה לסל';
      } else {
        atcBtn.disabled = true;
        atcLabel.textContent = 'אזל המלאי';
      }
    }

    if (pdpLink) {
      pdpLink.href = merged.url || '#';
      pdpLink.style.display = merged.url ? '' : 'none';
    }

    _qModalPreviousFocus = document.activeElement;
    modal.hidden = false;
    modal.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    const closeBtn = modal.querySelector('.q-product-modal__close');
    if (closeBtn) closeBtn.focus();
  }

  function closeQuestionnaireProductModal() {
    const modal = document.getElementById('q-product-detail-modal');
    if (!modal) return;
    modal.hidden = true;
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (_qModalPreviousFocus && typeof _qModalPreviousFocus.focus === 'function') {
      _qModalPreviousFocus.focus();
    }
    _qModalPreviousFocus = null;
  }

  function saveResultsState(products) {
    try {
      sessionStorage.setItem(
        QUESTIONNAIRE_RESULTS_STATE_KEY,
        JSON.stringify({
          products: Array.isArray(products) ? products : [],
          userText: typeof window.__questionnaireMatchUserText === 'string' ? window.__questionnaireMatchUserText : '',
          vendorOptions: Array.isArray(window.__questionnaireVendorOptions) ? window.__questionnaireVendorOptions : null,
          selectedVendor:
            typeof window.__questionnaireSelectedVendor === 'string' ? window.__questionnaireSelectedVendor : '',
          vendorAssignmentUserText:
            typeof window.__questionnaireVendorAssignmentForText === 'string'
              ? window.__questionnaireVendorAssignmentForText
              : '',
          vendorOptionsByQty:
            window.__questionnaireVendorOptionsByQty && typeof window.__questionnaireVendorOptionsByQty === 'object'
              ? window.__questionnaireVendorOptionsByQty
              : null,
          selectedVendorByQty:
            window.__questionnaireSelectedVendorByQty && typeof window.__questionnaireSelectedVendorByQty === 'object'
              ? window.__questionnaireSelectedVendorByQty
              : null,
          questionnaireParams: window.__questionnaireParams || null,
          savedAt: Date.now(),
        })
      );
    } catch (error) {
      console.warn('Failed to save questionnaire results state:', error);
    }
  }

  function loadResultsState() {
    try {
      const rawState = sessionStorage.getItem(QUESTIONNAIRE_RESULTS_STATE_KEY);
      if (!rawState) return null;
      const parsedState = JSON.parse(rawState);
      if (!parsedState || !Array.isArray(parsedState.products)) return null;
      if (typeof parsedState.userText === 'string' && parsedState.userText.length) {
        window.__questionnaireMatchUserText = parsedState.userText;
      }
      if (Array.isArray(parsedState.vendorOptions) && parsedState.vendorOptions.length) {
        window.__questionnaireVendorOptions = parsedState.vendorOptions.slice();
      } else if (parsedState.vendorByQty && typeof parsedState.vendorByQty === 'object') {
        const legacy = parsedState.vendorByQty[5] || parsedState.vendorByQty['5'];
        const v = (legacy != null && String(legacy).trim() !== '' ? String(legacy) : Object.values(parsedState.vendorByQty)[0]) || '';
        if (v) {
          window.__questionnaireSelectedVendor = String(v).toLowerCase();
        }
      }
      if (typeof parsedState.selectedVendor === 'string' && parsedState.selectedVendor.trim() !== '') {
        window.__questionnaireSelectedVendor = parsedState.selectedVendor.trim().toLowerCase();
      }
      if (parsedState.vendorOptionsByQty && typeof parsedState.vendorOptionsByQty === 'object') {
        window.__questionnaireVendorOptionsByQty = parsedState.vendorOptionsByQty;
      }
      if (parsedState.selectedVendorByQty && typeof parsedState.selectedVendorByQty === 'object') {
        window.__questionnaireSelectedVendorByQty = parsedState.selectedVendorByQty;
      }
      if (parsedState.questionnaireParams && typeof parsedState.questionnaireParams === 'object') {
        window.__questionnaireParams = parsedState.questionnaireParams;
      }
      if (typeof parsedState.vendorAssignmentUserText === 'string' && parsedState.vendorAssignmentUserText.length) {
        window.__questionnaireVendorAssignmentForText = parsedState.vendorAssignmentUserText;
      } else if (
        (Array.isArray(parsedState.vendorOptions) && parsedState.vendorOptions.length) ||
        (parsedState.vendorByQty && typeof window.__questionnaireMatchUserText === 'string')
      ) {
        window.__questionnaireVendorAssignmentForText = window.__questionnaireMatchUserText;
      }
      return parsedState.products;
    } catch (error) {
      console.warn('Failed to load questionnaire results state:', error);
      return null;
    }
  }

  function clearResultsState() {
    try {
      sessionStorage.removeItem(QUESTIONNAIRE_RESULTS_STATE_KEY);
    } catch (error) {
      console.warn('Failed to clear questionnaire results state:', error);
    }
    window.__questionnaireVendorOptionsByQty = null;
    window.__questionnaireSelectedVendorByQty = null;
  }

  function restartQuestionnaire() {
    trackQuestionnaireAnalyticsClick('Quiz - Restart', {
      'Restart Type': 'Restart',
    });
    clearResultsState();
    window.__questionnaireResultsScreenTracked = false;
