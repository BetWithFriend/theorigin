              height="600">
          </div>
          <div class="q-product-modal__content">
            <h2 id="q-product-modal-title" class="q-product-modal__title"></h2>
            <p id="q-product-modal-vendor" class="q-product-modal__vendor"></p>
            <p
              id="q-product-modal-short"
              class="q-product-modal__lead"
              hidden></p>
            <div
              id="q-product-modal-chips"
              class="q-product-modal__chips"
