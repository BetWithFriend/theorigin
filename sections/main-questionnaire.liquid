  function setupBundleTableRowActivation() {
    var tbody = document.getElementById('q-bundle-table-body');
    if (!tbody || _qBundleTableClickBound) return;
    _qBundleTableClickBound = true;
    tbody.addEventListener('click', function (e) {
      var row = e.target.closest('.q-bundle-table__row');
      if (!row) return;
      var pid = row.getAttribute('data-product-id');
      if (!pid) return;
      var pool = window.__qResultsShownProducts;
      var found =
        Array.isArray(pool) &&
        pool.find(function (p) {
          return p && String(p.id) === String(pid);
        });
      if (found) openQuestionnaireProductModal(found);
