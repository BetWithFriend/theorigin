          class="questionnaire-qty-options"
          role="group"
          aria-label="חבילות קפה במארז">
          <button
            type="button"
            class="qty-option"
            data-qty="3">
            <span class="qty-option__num">3</span>
          </button>
          <button
            type="button"
            class="qty-option selected"
            data-qty="5">
            <span class="qty-option__num">5</span>
          </button>
          <button
            type="button"
            class="qty-option qty-option--with-discount"
            data-qty="7">
            <span class="qty-option__num">7</span>
            <span class="qty-option__discount">10% הנחה</span>
          </button>
        </div>
