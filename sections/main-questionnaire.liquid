  function saveResultsState(products) {
    try {
      sessionStorage.setItem(
        QUESTIONNAIRE_RESULTS_STATE_KEY,
        JSON.stringify({
          products: Array.isArray(products) ? products : [],
          userText: typeof window.__questionnaireMatchUserText === 'string' ? window.__questionnaireMatchUserText : '',
          vendorByQty:
            window.__questionnaireVendorByQty && typeof window.__questionnaireVendorByQty === 'object'
              ? window.__questionnaireVendorByQty
              : null,
          vendorAssignmentUserText:
            typeof window.__questionnaireVendorAssignmentForText === 'string'
              ? window.__questionnaireVendorAssignmentForText
              : '',
          savedAt: Date.now(),
        })
      );
    } catch (error) {
      console.warn('Failed to save questionnaire results state:', error);
    }
  }

  function loadResultsState() {
    try {
      const rawState = sessionStorage.getItem(QUESTIONNAIRE_RESULTS_STATE_KEY);
      if (!rawState) return null;
      const parsedState = JSON.parse(rawState);
      if (!parsedState || !Array.isArray(parsedState.products)) return null;
      if (typeof parsedState.userText === 'string' && parsedState.userText.length) {
        window.__questionnaireMatchUserText = parsedState.userText;
      }
      if (parsedState.vendorByQty && typeof parsedState.vendorByQty === 'object') {
        window.__questionnaireVendorByQty = parsedState.vendorByQty;
      }
      if (typeof parsedState.vendorAssignmentUserText === 'string' && parsedState.vendorAssignmentUserText.length) {
        window.__questionnaireVendorAssignmentForText = parsedState.vendorAssignmentUserText;
      } else if (parsedState.vendorByQty && typeof window.__questionnaireMatchUserText === 'string') {
        window.__questionnaireVendorAssignmentForText = window.__questionnaireMatchUserText;
      }
      return parsedState.products;
    } catch (error) {
      console.warn('Failed to load questionnaire results state:', error);
      return null;
    }
  }

  function clearResultsState() {
    try {
      sessionStorage.removeItem(QUESTIONNAIRE_RESULTS_STATE_KEY);
    } catch (error) {
      console.warn('Failed to clear questionnaire results state:', error);
    }
  }

  function restartQuestionnaire() {
    clearResultsState();
    window.location.reload();
  }
  function getSuitTasteProfile(selectedFilters) {
    if (!window.questionnaireData) return [];

    // Get all possible values if filter is empty or not selected
    const allPrepMethods = [...new Set(window.questionnaireData.map((row) => row.prepMethod))];
    const allRoastLevels = [...new Set(window.questionnaireData.map((row) => row.roastLevel))];

    const prepMethods =
      window.appliedFilters['filter.p.m.custom.coffee_prep_methods'] &&
      window.appliedFilters['filter.p.m.custom.coffee_prep_methods'].length
        ? window.appliedFilters['filter.p.m.custom.coffee_prep_methods']
        : allPrepMethods;

    const roastLevels =
      window.appliedFilters['filter.p.m.custom.coffee_roast_level'] &&
      window.appliedFilters['filter.p.m.custom.coffee_roast_level'].length
        ? window.appliedFilters['filter.p.m.custom.coffee_roast_level']
        : allRoastLevels;

    // Find all matching tasteProfiles
    const tasteProfiles = window.questionnaireData
      .filter(
        (row) =>
          prepMethods.includes(row.prepMethod) &&
          roastLevels.includes(row.roastLevel) &&
          (selectedFilters === '' || row.tasteProfile === selectedFilters)
      )
      .map((row) => row.tastes);

    // Return unique taste profiles
    return [...new Set(tasteProfiles)];
  }

  function getFilters(filterName, stepIndex) {
    // Get all selected items in the current active step
    const activeWrapper = document.querySelector('.questionnaire-icons-wrapper.active');
    if (!activeWrapper) return;

    const selectedItems = activeWrapper.querySelectorAll('.questionnaire-selection-wrapper.selected');
    if (selectedItems.length === 0) return;

    // Get selected filter values
    let selectedValues = [];
    selectedItems.forEach((item) => {
      const filterValue = item.getAttribute('data-filter-value');
      if (filterValue) {
        // Handle comma-separated values
        const values = filterValue.split(',').map((v) => v.trim());
        selectedValues.push(...values);
      }
    });

    analytics.trackClick('Filter select', {
      Filter: filterName,
      step: stepIndex,
      filters: selectedValues,
    });

    window.appliedFilters[filterName] = [];
    if (selectedValues.length === 0) {
      goToNextStep(stepIndex);
    } else {
      selectedValues.forEach((value) => {
        // if (!window.appliedFilters[filterName])

        if (filterName === 'filter.p.m.custom.coffee_tastes') {
          const coffeeTastes = getSuitTasteProfile(value);
          coffeeTastes.forEach((tastes) => {
            tastesArray = tastes.split(',').map((t) => t.trim());
            tastesArray.forEach((taste) => {
              if (!window.appliedFilters[filterName].includes(taste)) {
                window.appliedFilters[filterName].push(taste);
              }
            });
          });
        } else {
          window.appliedFilters[filterName].push(value);
        }
      });
      goToNextStep(stepIndex);
    }
    // Update disabled state for taste options
    updateTasteOptionsDisabledState();
  }

  function goToPreviousStep(step = null) {
    if (step === 0) {
      window.history.back();
      return;
    }

    // Get the current active wrapper
    const currentActiveWrapper = document.querySelector('.questionnaire-icons-wrapper.active');

    if (!currentActiveWrapper) return;

    // Remove active class from current wrapper
    currentActiveWrapper.classList.remove('active');

    // Find the previous questionnaire-icons-wrapper
    const previousWrapper = currentActiveWrapper.previousElementSibling;

    // Add active class to previous wrapper if it exists and is a questionnaire-icons-wrapper
    if (previousWrapper && previousWrapper.classList.contains('questionnaire-icons-wrapper')) {
      previousWrapper.classList.add('active');

      // Update button state for the new active step
      updateSelectButton();

      // Update disabled state for taste options
      updateTasteOptionsDisabledState();
    }

    analytics.trackClick('Quiz Step Back', {
      step: step,
    });
  }

  function goToNextStep(stepIndex) {
    //   // Get the current active wrapper
    const currentActiveWrapper = document.querySelector('.questionnaire-icons-wrapper.active');

    if (!currentActiveWrapper) return;

    // Remove active class from current wrapper
    currentActiveWrapper.classList.remove('active');

    // Find the next questionnaire-icons-wrapper
    const nextWrapper = currentActiveWrapper.nextElementSibling;

    // Add active class to next wrapper if it exists and is a questionnaire-icons-wrapper
    if (nextWrapper && nextWrapper.classList.contains('questionnaire-icons-wrapper')) {
      nextWrapper.classList.add('active');
      updateSelectButton();
      // Disable the btn again for every iteration
      const selectBtn = nextWrapper.querySelector('.questionnaire-select-btn');
      const hasActive = !!nextWrapper.querySelector('.questionnaire-selection-wrapper.selected');

      if (selectBtn && !hasActive) {
        selectBtn.disabled = true;
        selectBtn.classList.add('disabled');
      }
      // Update disabled state for taste options
      updateTasteOptionsDisabledState();
    }

    if (stepIndex === 3) {
      //   // Show loader for 3 seconds if it is active on page load
      const loaderWrapper = document.querySelector('.questionnaire-icons-wrapper.active .questionnaire-loader-wrapper');
      if (loaderWrapper) {
        const questionnaireTitle = document.querySelector('.questionnaire-title');
        questionnaireTitle.classList.add('hidden');
        setTimeout(function () {
          const loaderIconsWrapper = loaderWrapper.closest('.questionnaire-icons-wrapper');
          if (loaderIconsWrapper) {
            loaderIconsWrapper.classList.remove('active');
            const mainWrapper = document.querySelector('.questionnaire-wrapper');
            // Hide main element
            if (mainWrapper) {
              mainWrapper.classList.add('hidden');
            }
            // Show the "lets be friends" section
            // Get the local storage item to prevent showing the form again
            const mailSubscriptionPage = localStorage.getItem('mailSubscriptionPage');
            if (mailSubscriptionPage !== 'true') {
              const friendsWrapper = document.querySelector('.lets-be-friends-wrapper');
              if (friendsWrapper) {
                friendsWrapper.classList.add('active');
                //save localStorage item to prevent showing the form again
                localStorage.setItem('mailSubscriptionPage', 'true');
                analytics.trackScreenView('Subscription', {
                  page_load_time: performance.now(),
                });
              }
            } else {
              // Redirect to collection page with filters
              redirectToCollectionWithFilters();
            }
          }
        }, 2000);
      }

      enableScrollWithEvents();
    }
  }

  function redirectToCollectionWithFilters() {
    // Collect text from selected UI elements to support Hebrew matching
    const selectedWrappers = document.querySelectorAll('.questionnaire-selection-wrapper.selected');
    const selectedTexts = Array.from(selectedWrappers).map((el) => {
      const textEl = el.querySelector('.questionnaire-text');
      return textEl ? textEl.innerText : '';
    });

    // Also collect applied filter values (English)
    const filterValues = [];
    for (const key in window.appliedFilters) {
      if (Array.isArray(window.appliedFilters[key])) {
        filterValues.push(...window.appliedFilters[key]);
      }
    }

    const userText = selectedTexts.join(' ') + ' ' + filterValues.join(' ');
    console.log('User Text for matching:', userText);

    window.__questionnaireMatchUserText = userText;
    const bundleQty = getQuestionnaireBundleQtyFromDom();
    const matchedCoffees = matchQuestionnaireCoffees(userText, bundleQty);
    console.log('Matched Coffees:', matchedCoffees);
    saveResultsState(matchedCoffees);

    renderQuestionnaireResults(matchedCoffees);
  }

  function renderQuestionnaireResults(matchedCoffees) {
    const products = Array.isArray(matchedCoffees) ? matchedCoffees : [];

    // Render results in the new step
    const resultsGrid = document.getElementById('Slider-questionnaireResultsGrid');
    const resultsStep = document.getElementById('questionnaireResultsStep');
    const mainWrapper = document.querySelector('.questionnaire-wrapper');
    const friendsWrapper = document.querySelector('.lets-be-friends-wrapper');
    document.body.classList.remove('questionnaire-wrapper-open');

    // Helper: render up to `qty` slides and (re-)init the carousel
    function renderBundleList(allProducts, qty) {
      const listEl = document.getElementById('qBundleList');
      if (!listEl) return;
      const shownProducts = allProducts.slice(0, qty);
      if (!shownProducts.length) {
        listEl.innerHTML = '<li class="results-bundle-list__empty">אין מוצרים להצגה</li>';
        return;
      }

      listEl.innerHTML = shownProducts
        .map(function (product, index) {
          const vendorOrTitle = (product.vendor || '').trim() || (product.title || '').trim() || 'תערובת';
          return '<li class="results-bundle-list__item">' + (index + 1) + '. ' + vendorOrTitle + '</li>';
        })
        .join('');
    }

    function renderCarousel(products, qty) {
      const shown = products.slice(0, qty);

      // Update counter text
      const counterEl = document.getElementById('q-carousel-counter');
      if (counterEl) {
        counterEl.textContent = `(1/${shown.length})`;
      }

      if (shown.length > 0) {
        resultsGrid.innerHTML = shown
          .map(
            (product) =>
              `<div class="q-carousel-slide" data-product-id="${product.id}">${product.html_card}</div>`
          )
          .join('');
      } else {
        resultsGrid.innerHTML =
          '<div class="q-carousel-slide q-carousel-slide--empty">לא נמצאו תוצאות מדוייקות, נסו שנית.</div>';
      }
      renderBundleList(products, qty);
      renderBundleTableFromProducts(shown);
      initProductCarousel(shown);
    }

    if (resultsGrid && resultsStep && mainWrapper) {
      resetBundleViewToCarousel();
      // Determine initial qty from the selected option (default 5)
      const initialQtyEl = document.querySelector('.questionnaire-qty-selector-wrapper .qty-option.selected');
      const initialQty = initialQtyEl
        ? parseInt(initialQtyEl.getAttribute('data-qty') || initialQtyEl.textContent.trim(), 10) || 5
        : 5;

      // Render only the first `initialQty` products
      renderCarousel(products, initialQty);
      // setupBundleListToggle();

      // Wire up qty selector — re-render carousel + price on change
      const qtyWrapper = document.querySelector('.questionnaire-qty-selector-wrapper');
      if (qtyWrapper) {
        const newQtyWrapper = qtyWrapper.cloneNode(true);
        qtyWrapper.parentNode.replaceChild(newQtyWrapper, qtyWrapper);
        newQtyWrapper.addEventListener('click', function (e) {
          const opt = e.target.closest('.qty-option');
          if (!opt) return;
          newQtyWrapper.querySelectorAll('.qty-option').forEach(function (o) {
            o.classList.remove('selected');
          });
          opt.classList.add('selected');
          const newQty =
            parseInt(opt.getAttribute('data-qty') || opt.textContent.trim(), 10) || products.length;
          let nextProducts = products;
          const ut = window.__questionnaireMatchUserText;
          if (typeof ut === 'string' && ut.length) {
            nextProducts = matchQuestionnaireCoffees(ut, newQty);
            saveResultsState(nextProducts);
          }
          renderCarousel(nextProducts, newQty);
          updateQuestionnaireQtyOptionWeights();
        });
      }

      updateQuestionnaireQtyOptionWeights();

      // Hide friends wrapper if open
      if (friendsWrapper) {
        friendsWrapper.classList.remove('active');
      }

      // Show main wrapper
      mainWrapper.classList.remove('hidden');

      // Hide all other steps
      const steps = document.querySelectorAll('.questionnaire-icons-wrapper');
      steps.forEach((step) => step.classList.remove('active'));

      // Show results step
      resultsStep.classList.add('active');
      mainWrapper.classList.add('results-step-visible');

      // Scroll to top of results?
      resultsStep.scrollIntoView({ behavior: 'smooth' });
    }

    const questionnaireWrapper = document.getElementById('questionnaireWrapperDesktop');
    if (questionnaireWrapper) {
      questionnaireWrapper.classList.remove('initializing');
    }
  }

  function initProductCarousel(products) {
    const track = document.getElementById('Slider-questionnaireResultsGrid');
    if (!track) return;

    if (track._qCarouselTeardown) {
      track._qCarouselTeardown();
    }

    const slides = Array.from(track.querySelectorAll('.q-carousel-slide'));
    let current = 0;
    const viewport = track.parentElement;
    const thumbsEl = document.getElementById('q-selection-info-thumbs');
    /** Fraction of viewport width for each slide (smaller = more of prev/next visible). */
    const Q_CAROUSEL_SLIDE_FRAC = 0.46;

    function applySlideWidths() {
      if (!viewport) return;
      const vw = viewport.clientWidth;
      const slideW = vw * Q_CAROUSEL_SLIDE_FRAC;
      const pad = Math.max(0, (vw - slideW) / 2);
      track.style.transform = '';
      track.style.transition = '';
      track.style.paddingLeft = pad + 'px';
      track.style.paddingRight = pad + 'px';
      slides.forEach(function (slide) {
        slide.style.flex = '0 0 ' + slideW + 'px';
        slide.style.width = slideW + 'px';
        slide.style.minWidth = slideW + 'px';
      });
    }

    // ── Bundle price helpers ──────────────────────────────────────────────
    function getSelectedQty() {
      const sel = document.querySelector('.questionnaire-qty-selector-wrapper .qty-option.selected');
      if (!sel) return 1;
      const dq = sel.getAttribute('data-qty');
      if (dq) return parseInt(dq, 10) || 1;
      return parseInt(sel.textContent.trim(), 10) || 1;
    }

    function updateBundlePrice() {
      if (!products || products.length === 0) return;
      const qty = getSelectedQty();
      const n = products.length;

      // Each carousel product counts as 1. The qty selector is the total number
      // of products in the bundle (3, 5, or 7). We compute the average price per
      // product across all matched results, then multiply by qty.
      let sumCents = 0;
      let sumCompareCents = 0;
      products.forEach(function (p) {
        sumCents += p.price_cents || 0;
        sumCompareCents += p.price_cents || 0;
      });

      const avgCents = sumCents / n;
      const avgCompareCents = sumCompareCents / n;

      let totalCents = Math.round(avgCents * qty);
      const totalCompareCents = Math.round(avgCompareCents * qty);

      if (qty === 7) {
        totalCents = Math.round(totalCents * 0.9);
      }

      const formatMoney = function (cents) {
        return '\u20AA' + (cents / 100).toFixed(0);
      };

      const priceEl = document.getElementById('q-footer-price');
      const compareEl = document.getElementById('q-footer-price-compare');

      if (priceEl) priceEl.textContent = formatMoney(totalCents);

      if (compareEl) {
        if (totalCompareCents > totalCents) {
          compareEl.textContent = formatMoney(totalCompareCents);
          compareEl.style.display = '';
        } else {
          compareEl.textContent = '';
          compareEl.style.display = 'none';
        }
      }

      let totalGrams = 0;
      products.forEach(function (p) {
        totalGrams += p.weight_grams || 0;
      });
      const bundleWeightEl = document.getElementById('q-footer-bundle-weight');
      if (bundleWeightEl) {
        if (totalGrams > 0) {
          bundleWeightEl.textContent = '· סה״כ ' + totalGrams + ' גרם';
          bundleWeightEl.hidden = false;
        } else {
          bundleWeightEl.textContent = '';
          bundleWeightEl.hidden = true;
        }
      }
    }

    function renderSelectionThumbs() {
      if (!thumbsEl) return;

      thumbsEl.innerHTML = products
        .map(function (product, index) {
          const vendorOrTitle = (product.vendor || '').trim() || (product.title || '').trim() || 'תערובת';
          const image = product.image || '';
          const isActiveClass = index === current ? ' is-active' : '';
          const imageMarkup = image
            ? '<img class="questionnaire-selection-thumb__image" src="' +
              image +
              '" alt="' +
              vendorOrTitle +
              '" loading="lazy">'
            : '<span class="questionnaire-selection-thumb__fallback">' + (index + 1) + '</span>';

          return (
            '<button type="button" class="questionnaire-selection-thumb' +
            isActiveClass +
            '" data-index="' +
            index +
            '" role="tab" aria-selected="' +
            (index === current ? 'true' : 'false') +
            '" aria-label="' +
            vendorOrTitle +
            '" title="' +
            vendorOrTitle +
            '">' +
            imageMarkup +
            '</button>'
          );
        })
        .join('');

      thumbsEl.querySelectorAll('.questionnaire-selection-thumb').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const nextIndex = parseInt(btn.getAttribute('data-index') || '0', 10);
          if (Number.isNaN(nextIndex)) return;
          scrollToIndex(nextIndex, 'smooth');
        });
      });
    }

    function syncFooter(index) {
      const product = products && products[index];
      if (!product) return;

      // Update counter
      const counterEl = document.getElementById('q-carousel-counter');
      if (counterEl) {
        counterEl.textContent = `(${index + 1}/${products.length})`;
      }

      if (thumbsEl) {
        thumbsEl.querySelectorAll('.questionnaire-selection-thumb').forEach(function (thumb, thumbIndex) {
          const isActive = thumbIndex === index;
          thumb.classList.toggle('is-active', isActive);
          thumb.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
      }

      // Bundle price (all products × qty)
      updateBundlePrice();

      // Variant ID (for the visible product — informational; ATC adds the whole bundle)
      const variantInput = document.getElementById('q-footer-variant-id');
      if (variantInput) variantInput.value = product.variantId || '';

      // Button label & state — enabled only when every product in the bundle can be purchased
      const atcBtn = document.getElementById('q-footer-atc-btn');
      const atcLabel = document.getElementById('q-footer-atc-label');
      const bundleReady =
        products.length > 0 &&
        products.every(function (p) {
          return p && p.available && p.variantId;
        });
      if (atcBtn && atcLabel) {
        if (bundleReady) {
          atcBtn.disabled = false;
          atcLabel.textContent = 'רכישת המארז';
        } else {
          atcBtn.disabled = true;
          atcLabel.textContent = products.length && products.some(function (p) { return p && !p.available; })
            ? 'אזל המלאי'
            : 'רכישת המארז';
        }
      }
    }

    function slideMetrics() {
      if (!viewport) return { vw: 0, slideW: 0 };
      const vw = viewport.clientWidth;
      return { vw, slideW: vw * Q_CAROUSEL_SLIDE_FRAC };
    }

    function maxScrollLeft() {
      if (!viewport) return 0;
      return Math.max(0, viewport.scrollWidth - viewport.clientWidth);
    }

    /** Scroll position that places slide `index` in the horizontal center of the viewport. */
    function scrollLeftToCenterIndex(index) {
      const { vw, slideW } = slideMetrics();
      if (!viewport || slideW <= 0) return 0;
      const pad = (vw - slideW) / 2;
      const target = pad + index * slideW + slideW / 2 - vw / 2;
      return Math.max(0, Math.min(maxScrollLeft(), target));
    }

    function indexFromScrollLeft() {
      const { vw, slideW } = slideMetrics();
      if (!viewport || slideW <= 0 || slides.length === 0) return 0;
      const pad = (vw - slideW) / 2;
      const raw = (viewport.scrollLeft + vw / 2 - pad - slideW / 2) / slideW;
      return Math.max(0, Math.min(slides.length - 1, Math.round(raw)));
    }

    function updateSlideActiveClasses(index) {
      slides.forEach(function (slide, i) {
        slide.classList.toggle('active', i === index);
      });
    }

    function updateArrowDisabled() {
      if (!viewport) return;
      const p = document.getElementById('qCarouselPrev');
      const n = document.getElementById('qCarouselNext');
      const sl = viewport.scrollLeft;
      const maxS = maxScrollLeft();
      const eps = 2;
      if (p) p.disabled = sl <= eps;
      if (n) n.disabled = maxS <= eps || sl >= maxS - eps;
    }

    function syncFromScrollPosition() {
      const idx = indexFromScrollLeft();
      if (idx !== current) {
        current = idx;
        syncFooter(current);
      }
      updateSlideActiveClasses(idx);
      updateArrowDisabled();
    }

    function scrollToIndex(index, behavior) {
      if (!viewport || slides.length === 0) return;
      const i = Math.max(0, Math.min(index, slides.length - 1));
      const beh = behavior === 'instant' ? 'auto' : behavior || 'smooth';
      viewport.scrollTo({ left: scrollLeftToCenterIndex(i), behavior: beh });
    }

    // Wire up arrows — clone to clear any old listeners, then update refs
    const prevBtnOld = document.getElementById('qCarouselPrev');
    const nextBtnOld = document.getElementById('qCarouselNext');

    if (prevBtnOld) {
      const newPrev = prevBtnOld.cloneNode(true);
      prevBtnOld.parentNode.replaceChild(newPrev, prevBtnOld);
      newPrev.addEventListener('click', function () {
        scrollToIndex(indexFromScrollLeft() - 1, 'smooth');
      });
    }
    if (nextBtnOld) {
      const newNext = nextBtnOld.cloneNode(true);
      nextBtnOld.parentNode.replaceChild(newNext, nextBtnOld);
      newNext.addEventListener('click', function () {
        scrollToIndex(indexFromScrollLeft() + 1, 'smooth');
      });
    }

    function buildQuestionnaireBundleCartItems() {
      const byVariant = {};
      products.forEach(function (p) {
        if (!p || !p.variantId || !p.available) return;
        const vid = String(p.variantId);
        byVariant[vid] = (byVariant[vid] || 0) + 1;
      });
      return Object.keys(byVariant).map(function (vid) {
        return { id: Number(vid), quantity: byVariant[vid] };
      });
    }

    function closeQuestionnaireBundleReviewDrawer() {
      const drawer = document.getElementById('q-bundle-review-drawer');
      if (!drawer) return;
      drawer.hidden = true;
      drawer.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('overflow-hidden');
    }

    function openQuestionnaireBundleReviewDrawer() {
      const drawer = document.getElementById('q-bundle-review-drawer');
      const itemsEl = document.getElementById('q-bundle-drawer-items');
      const totalEl = document.getElementById('q-bundle-drawer-total');
      const totalWeightEl = document.getElementById('q-bundle-drawer-total-weight');
      const totalWeightNoteEl = document.getElementById('q-bundle-drawer-total-weight-note');
      if (!drawer || !itemsEl || !totalEl) return;

      const qty = getSelectedQty();
      const n = products.length;
      let sumCents = 0;
      let totalGrams = 0;
      products.forEach(function (p) {
        if (!p) return;
        sumCents += p.price_cents || 0;
        totalGrams += p.weight_grams || 0;
      });
      const avgCents = n ? sumCents / n : 0;
      let totalCents = Math.round(avgCents * qty);
      if (qty === 7) {
        totalCents = Math.round(totalCents * 0.9);
      }

      const formatMoney = function (cents) {
        return '\u20AA' + (cents / 100).toFixed(0);
      };

      itemsEl.innerHTML = products
        .map(function (p) {
          if (!p) return '';
          const title = escapeHtml((p.title || '').trim() || 'מוצר');
          const img = p.image
            ? '<img class="q-bundle-drawer__thumb-img" src="' + escapeHtml(p.image) + '" alt="" loading="lazy">'
            : '<span class="q-bundle-drawer__thumb-fallback" aria-hidden="true"></span>';
          const w = formatQuestionnaireProductWeight(p.weight_grams);
          return (
            '<div class="q-bundle-drawer__line">' +
            '<div class="q-bundle-drawer__thumb">' +
            img +
            '</div>' +
            '<div class="q-bundle-drawer__line-main">' +
            '<div class="q-bundle-drawer__line-title">' +
            title +
            '</div>' +
            '<div class="q-bundle-drawer__line-meta">' +
            '<span class="q-bundle-drawer__weight">' +
            escapeHtml(w) +
            '</span>' +
            '</div>' +
            '</div>' +
            '</div>'
          );
        })
        .join('');

      totalEl.textContent = formatMoney(totalCents);
      if (totalWeightEl) {
        totalWeightEl.textContent =
          totalGrams > 0 ? formatQuestionnaireBundleWeightKg(totalGrams) : '—';
      }
      if (totalWeightNoteEl) {
        totalWeightNoteEl.hidden = !totalGrams;
      }

      const dCheckout = document.getElementById('q-bundle-drawer-checkout');
      const dContinue = document.getElementById('q-bundle-drawer-continue-shopping');
      if (dCheckout) dCheckout.disabled = false;
      if (dContinue) dContinue.disabled = false;

      drawer.hidden = false;
      drawer.setAttribute('aria-hidden', 'false');
      document.body.classList.add('overflow-hidden');

      const focusClose = drawer.querySelector('.q-bundle-drawer__close');
      if (focusClose && typeof focusClose.focus === 'function') {
        setTimeout(function () {
          focusClose.focus();
        }, 0);
      }
    }

    function submitQuestionnaireBundleToCart(redirectUrl, activeLabelEl) {
      const items = buildQuestionnaireBundleCartItems();
      if (!items.length) return;

      closeQuestionnaireBundleReviewDrawer();

      const atcBtn = document.getElementById('q-footer-atc-btn');
      const atcLabel = document.getElementById('q-footer-atc-label');
      const shopLabel = document.getElementById('q-bundle-drawer-shop-label');
      const drawerCheckoutBtn = document.getElementById('q-bundle-drawer-checkout');
      const drawerContinueBtn = document.getElementById('q-bundle-drawer-continue-shopping');
      const originalAtc = atcLabel ? atcLabel.textContent : '';
      const originalShop = shopLabel ? shopLabel.textContent : '';

      if (atcBtn) atcBtn.disabled = true;
      if (drawerCheckoutBtn) drawerCheckoutBtn.disabled = true;
      if (drawerContinueBtn) drawerContinueBtn.disabled = true;
      if (activeLabelEl) activeLabelEl.textContent = 'מוסיף מוצרים...';

      if (typeof analytics !== 'undefined' && analytics.trackClick) {
        analytics.trackClick('Add To Cart', {
          Source: 'Quiz bundle',
          Items: items.length,
        });
      }

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items }),
      })
        .then(function (response) {
          if (!response.ok) {
            return response.json().then(function (err) {
              throw err;
            });
          }
          return response.json();
        })
        .then(function () {
          window.location.assign(redirectUrl);
        })
        .catch(function (err) {
          console.error('Questionnaire bundle add to cart:', err);
          if (activeLabelEl) activeLabelEl.textContent = 'שגיאה';
          if (atcBtn) atcBtn.disabled = false;
          if (drawerCheckoutBtn) drawerCheckoutBtn.disabled = false;
          if (drawerContinueBtn) drawerContinueBtn.disabled = false;
          setTimeout(function () {
            if (atcLabel) atcLabel.textContent = originalAtc;
            if (shopLabel) shopLabel.textContent = originalShop;
          }, 2000);
        });
    }

    const footerAtcFormEl = document.getElementById('q-footer-atc-form');
    if (footerAtcFormEl && footerAtcFormEl.parentNode) {
      const freshFooterForm = footerAtcFormEl.cloneNode(true);
      footerAtcFormEl.parentNode.replaceChild(freshFooterForm, footerAtcFormEl);
      freshFooterForm.addEventListener('submit', function (e) {
        e.preventDefault();
        openQuestionnaireBundleReviewDrawer();
      });
    }

    const bundleDrawerEl = document.getElementById('q-bundle-review-drawer');
    if (bundleDrawerEl) {
      bundleDrawerEl.querySelectorAll('[data-q-bundle-drawer-close]').forEach(function (node) {
        node.addEventListener('click', function () {
          closeQuestionnaireBundleReviewDrawer();
        });
      });
      bundleDrawerEl.addEventListener('keyup', function (e) {
        if (e.code === 'Escape') closeQuestionnaireBundleReviewDrawer();
      });
    }

    const bundleCheckoutBtn = document.getElementById('q-bundle-drawer-checkout');
    if (bundleCheckoutBtn) {
      bundleCheckoutBtn.addEventListener('click', function () {
        const atcLabel = document.getElementById('q-footer-atc-label');
        submitQuestionnaireBundleToCart('/checkout', atcLabel);
      });
    }

    const bundleContinueBtn = document.getElementById('q-bundle-drawer-continue-shopping');
    if (bundleContinueBtn) {
      bundleContinueBtn.addEventListener('click', function () {
        const shopLabel = document.getElementById('q-bundle-drawer-shop-label');
        submitQuestionnaireBundleToCart('/collections/חנות-קפה', shopLabel);
      });
    }

    renderSelectionThumbs();

    let carouselScrollRaf = null;
    function onCarouselViewportScroll() {
      if (carouselScrollRaf !== null) return;
      carouselScrollRaf = requestAnimationFrame(function () {
        carouselScrollRaf = null;
        syncFromScrollPosition();
      });
    }

    function openModalFromSlideTarget(target) {
      const card = target && target.closest ? target.closest('.questionnaire-product-card') : null;
      if (!card) return;
      const slide = target.closest('.q-carousel-slide');
      if (!slide || slide.classList.contains('q-carousel-slide--empty')) return;
      const pid = slide.getAttribute('data-product-id');
      if (!pid) return;
      const found = products.find(function (pr) {
        return String(pr.id) === String(pid);
      });
      if (!found) return;
      openQuestionnaireProductModal(found);
    }

    track.addEventListener('click', function (e) {
      openModalFromSlideTarget(e.target);
    });

    track.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter') return;
      openModalFromSlideTarget(e.target);
    });

    slides.forEach(function (slide) {
      if (slide.classList.contains('q-carousel-slide--empty')) return;
      const card = slide.querySelector('.questionnaire-product-card');
      if (card) card.setAttribute('tabindex', '0');
    });

    applySlideWidths();
    const ro = new ResizeObserver(function () {
      applySlideWidths();
      if (viewport && slides.length && !slides[0].classList.contains('q-carousel-slide--empty')) {
        viewport.scrollLeft = scrollLeftToCenterIndex(current);
      }
      syncFromScrollPosition();
    });
    if (viewport) {
      viewport.addEventListener('scroll', onCarouselViewportScroll, { passive: true });
      ro.observe(viewport);
      track._qCarouselResizeObserver = ro;
    }

    if (viewport && slides.length && !slides[0].classList.contains('q-carousel-slide--empty')) {
      viewport.scrollLeft = scrollLeftToCenterIndex(0);
    }
    current = indexFromScrollLeft();
    syncFooter(current);
    updateSlideActiveClasses(current);
    updateArrowDisabled();

    track._qCarouselTeardown = function () {
      if (carouselScrollRaf !== null) {
        cancelAnimationFrame(carouselScrollRaf);
        carouselScrollRaf = null;
      }
      if (viewport) {
        viewport.removeEventListener('scroll', onCarouselViewportScroll);
      }
      if (track._qCarouselResizeObserver) {
        track._qCarouselResizeObserver.disconnect();
        track._qCarouselResizeObserver = null;
      }
    };
  }

  function arrayToQueryString(filterData) {
    const params = new URLSearchParams();

    for (const key in filterData) {
      if (filterData.hasOwnProperty(key) && Array.isArray(filterData[key])) {
        const values = filterData[key];
        values.forEach((value) => {
          params.append(key, value);
        });
      }
    }

    return params.toString();
  }
  // // Keep your existing functions unchanged
  function updateSelectButton() {
    // Get the current active questionnaire step
    const activeWrapper = document.querySelector('.questionnaire-icons-wrapper.active');

    if (!activeWrapper) return;

    // Get all selected items in the current active step
    const selectedItems = activeWrapper.querySelectorAll('.questionnaire-selection-wrapper.selected');

    // Get the button in the current active step
    const selectBtn = activeWrapper.querySelector('.questionnaire-select-btn');

    if (selectBtn) {
      // Enable button if one or more items are selected, disable otherwise
      if (selectedItems.length > 0) {
        const hasEmptyFilterValue = Array.from(selectedItems).some(
          (item) => item.getAttribute('data-filter-value') === ''
        );
        selectBtn.disabled = false;
        selectBtn.classList.remove('disabled');
        selectBtn.textContent = !hasEmptyFilterValue
          ? selectedItems.length && selectedItems.length === 1
            ? questionnaireSettings.continueSingleText
            : questionnaireSettings.continueMultipleText.replace('{count}', selectedItems.length)
          : `המשיכו`;
      } else {
        selectBtn.disabled = true;
        selectBtn.classList.add('disabled');
        selectBtn.textContent = questionnaireSettings.selectButtonText;
      }
    }
  }

  let scrollHandler = function (e) {
    e.preventDefault();
    e.stopPropagation();
    return false;
  };

  function disableScrollWithEvents() {
    window.addEventListener('wheel', scrollHandler, { passive: false });
    window.addEventListener('touchmove', scrollHandler, { passive: false });
  }

  function enableScrollWithEvents() {
    if (scrollHandler) {
      window.removeEventListener('wheel', scrollHandler);
      window.removeEventListener('touchmove', scrollHandler);
    }
  }

  function closeForm(skip = false) {
    enableScrollWithEvents();

    analytics.trackClick('Close Quiz', {
      'Skip Email': skip,
    });

    // Redirect to collection page with filters if skip is true, otherwise go to close redirect
    if (skip) {
      redirectToCollectionWithFilters();
    } else {
      window.location.href = questionnaireSettings.closeRedirect || '/';
    }
  }

  function subscribeUser(email) {
    analytics.trackClick('Quiz Email Subscribe', {
      email: email,
    });

    if (isValidEmail(email)) {
      const url = 'https://elghwmw2jd3c5ve65agcrezqru0lrwtc.lambda-url.us-east-1.on.aws/';
      const data = { email };

      fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      })
        // .then(response => response.json())
        .then((data) => {
          redirectToCollectionWithFilters();
        })
        .catch((error) => {
          console.error('Error subscribing:', error);
        });
    } else {
      redirectToCollectionWithFilters();
    }
  }

  // Email validation helper function
  function isValidEmail(email) {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return emailRegex.test(email);
  }

