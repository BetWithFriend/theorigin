  function closeQuestionnaireProductModal() {
    const modal = document.getElementById('q-product-detail-modal');
    if (!modal) return;
    modal.hidden = true;
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (_qModalPreviousFocus && typeof _qModalPreviousFocus.focus === 'function') {
      _qModalPreviousFocus.focus();
    }
    _qModalPreviousFocus = null;
