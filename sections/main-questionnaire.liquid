    // Event delegation for quantity selector interaction (clicks may hit inner spans)
    document.addEventListener('click', function (e) {
      const opt = e.target.closest('.qty-option');
      if (!opt) return;
      const wrapper = opt.closest('.questionnaire-qty-options');
      if (wrapper) {
        wrapper.querySelectorAll('.qty-option').forEach((el) => el.classList.remove('selected'));
        opt.classList.add('selected');
      }
    });

    const startOverButton = document.querySelector('.questionnaire-start-over');
    if (startOverButton) {
      startOverButton.onclick = restartQuestionnaire;
    }

    const savedResultsProducts = loadResultsState();
    if (savedResultsProducts) {
      let productsToShow = savedResultsProducts;
      if (typeof window.__questionnaireMatchUserText === 'string' && window.__questionnaireMatchUserText.length) {
        const q = getQuestionnaireBundleQtyFromDom();
        productsToShow = matchQuestionnaireCoffees(window.__questionnaireMatchUserText, q);
        saveResultsState(productsToShow);
      }
      renderQuestionnaireResults(productsToShow);
    } else {
      const questionnaireWrapper = document.getElementById('questionnaireWrapperDesktop');
      if (questionnaireWrapper) {
        questionnaireWrapper.classList.remove('initializing');
      }
    }
