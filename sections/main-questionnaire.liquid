  function renderBundleTableFromProducts(shownProducts) {
    var tbody = document.getElementById('q-bundle-table-body');
    if (!tbody) return;
    window.__qResultsShownProducts = shownProducts;
    setupBundleTableRowActivation();
    if (!shownProducts || !shownProducts.length) {
      tbody.innerHTML =
        '<tr><td colspan="3" class="q-bundle-table__empty">אין מוצרים להצגה</td></tr>';
      return;
    }
    tbody.innerHTML = shownProducts
      .map(function (p) {
        var merged = mergeProductFromCatalog(p) || p;
        var title = escapeHtml((merged.title || '').trim() || '—');
        var imgUrl = merged.image ? escapeHtml(merged.image) : '';
        var thumb = imgUrl
          ? '<img class="q-bundle-table__thumb-img" src="' +
            imgUrl +
            '" alt="" loading="lazy" width="44" height="44">'
          : '<span class="q-bundle-table__thumb-fallback" aria-hidden="true"></span>';
        var mf = merged.metafields || {};
        var tasteIcons = buildBundleTableTasteProfileIconsHtml(merged);
        var tasteCell = tasteIcons || '—';
        var roastRaw = getBundleTableRoastDisplay(mf);
        var roastCell = roastRaw ? 'קלייה ' + escapeHtml(roastRaw) : '—';
        return (
          '<tr class="q-bundle-table__row" data-product-id="' +
          escapeHtml(String(merged.id)) +
          '">' +
          '<td class="q-bundle-table__td q-bundle-table__td--product"><div class="q-bundle-table__product">' +
          thumb +
          '<span class="q-bundle-table__title">' +
          title +
          '</span></div></td>' +
          '<td class="q-bundle-table__td q-bundle-table__td--taste">' +
          tasteCell +
          '</td>' +
          '<td class="q-bundle-table__td q-bundle-table__td--roast">' +
          roastCell +
          '</td>' +
          '</tr>'
        );
      })
      .join('');
  }

