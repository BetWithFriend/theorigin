{%- comment -%} Lazy load questionnaire CSS {%- endcomment -%}
<link
  rel="preload"
  href="{{ 'questionnaire.css' | asset_url }}"
  as="style"
  onload="this.onload=null;this.rel='stylesheet'"
>
<noscript>{{ 'questionnaire.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'template-collection.css' | asset_url | stylesheet_tag }}</noscript>

<div class="questionnaire-wrapper" id="questionnaireWrapperDesktop">
  <div class="questionnaire-icons-wrapper active">
    {% paginate collections.all.products by 1000 %}
      <script>
        window.allProducts = [
          {% for product in collections.all.products %}
            {%- capture card_html -%}
            {% comment %} <li class="grid__item slider__slide grid-item-feed" id="Slide-{{ section.id }}-{{ product.id }}"> {% endcomment %}
              {% render 'questionnaire-product', card_product: product %}
            {% comment %} </li> {% endcomment %}
            {%- endcapture -%}
             {% unless product.tags contains 'bundle' %}
            {
                "id": {{ product.id }},
                "title": {{ product.title | json }},
                "handle": {{ product.handle | json }},
                "vendor": {{ product.vendor | json }},
                "price": {{ product.price | money | json }},
                "price_cents": {{ product.price }},
                "compare_at_price_cents": {{ product.compare_at_price | default: 0 }},
                "variantId": {{ product.selected_or_first_available_variant.id }},
                "available": {{ product.selected_or_first_available_variant.available }},
                "image": {{ product.featured_image | image_url: width: 600 | json }},
                "metafields": {
                  "coffee_roast_level": {{ product.metafields.custom.coffee_roast_level | json }},
                  "coffee_prep_methods": {{ product.metafields.custom.coffee_prep_methods }},
                  "coffee_tastes": {{ product.metafields.custom.coffee_tastes }}
                },
                "html_card": {{ card_html | json }}
            },
              {% endunless %}
          {% endfor %}
        ];
      </script>
    {% endpaginate %}

    {% for product in collection.products %}
      <script>
        console.log('boom2', {{ product | json }});
      </script>
      <!-- Access product data here -->
      <h3>{{ product.title }}</h3>
      <p>{{ product.description }}</p>
    {% endfor %}

