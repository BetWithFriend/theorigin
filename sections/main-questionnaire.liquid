      <div class="questionnaire-progress-bar filled">&nbsp;</div>
      <div class="questionnaire-progress-bar">&nbsp;</div>
    </div>
  </div>
  <div class="questionnaire-icons-wrapper ">
    <div class="questionnaire-title-wrapper">
      <div class="questionnaire-close-icon" onclick="closeForm()">
        <svg
