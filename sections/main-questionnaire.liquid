          (function () {
      var INTRO_FLAG = 'questionnaireShowIntro';
      var introParams = new URLSearchParams(window.location.search);
      var showIntro =
        sessionStorage.getItem(INTRO_FLAG) === '1' || introParams.get('intro') === '1';
