{%- assign default_continue_multiple = 'המשיכו עם [count] בחירות' -%}
{%- assign continue_multiple_raw = section.settings.continue_multiple_text | default: default_continue_multiple -%}
{%- assign continue_multiple_js = continue_multiple_raw | replace: '[count]', '{count}' -%}
{%- assign redirect_collection_url = section.settings.redirect_collection | default: '/collections/all' -%}
{%- assign close_redirect_url = section.settings.close_redirect | default: '/' -%}
{%- assign select_btn_text = section.settings.select_button_text | default: 'בחרו אפשרות' -%}
{%- assign continue_single_text = section.settings.continue_single_text | default: 'המשיכו עם בחירה אחת' -%}
<div>
  <div id="my-custom-results-area"></div>
</div>
<script>
  // Pass schema settings to JavaScript
  const questionnaireSettings = {
    redirectCollection: '{{ redirect_collection_url }}',
    closeRedirect: '{{ close_redirect_url }}',
    selectButtonText: '{{ select_btn_text }}',
    continueSingleText: '{{ continue_single_text }}',
    continueMultipleText: '{{ continue_multiple_js }}',
  };
  const QUESTIONNAIRE_RESULTS_STATE_KEY = 'questionnaireResultsState';
  let _qModalPreviousFocus = null;

  function getQuestionnaireBundleQtyFromDom() {
    const sel = document.querySelector('.questionnaire-qty-selector-wrapper .qty-option.selected');
    if (!sel) return 5;
    const dq = sel.getAttribute('data-qty');
    const n = dq ? parseInt(dq, 10) : parseInt(sel.textContent.trim(), 10);
    return [3, 5, 7].includes(n) ? n : 5;
  }

  function shuffleVendorList(arr) {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      const t = a[i];
      a[i] = a[j];
      a[j] = t;
    }
    return a;
  }

  /**
   * Picks three vendors for 3 / 5 / 7 pack sizes: randomly shuffled, distinct when
   * at least three matching vendors exist; otherwise reuses from the available pool.
   */
  function pickRandomVendorsPerBundleQty(uniqueVendorsLower) {
    const uniq = [...new Set((uniqueVendorsLower || []).map((v) => (v || '').trim().toLowerCase()).filter(Boolean))];
    if (!uniq.length) {
      return { 3: '', 5: '', 7: '' };
    }
    const shuffled = shuffleVendorList(uniq);
    let a;
    let b;
    let c;
    if (shuffled.length >= 3) {
      a = shuffled[0];
      b = shuffled[1];
      c = shuffled[2];
    } else if (shuffled.length === 2) {
      a = shuffled[0];
      b = shuffled[1];
      c = shuffled[Math.random() < 0.5 ? 0 : 1];
    } else {
      a = b = c = shuffled[0];
    }
    return { 3: a, 5: b, 7: c };
  }

  function matchQuestionnaireCoffees(userText, bundleQty) {
    const qty =
      bundleQty == null || bundleQty === undefined ? getQuestionnaireBundleQtyFromDom() : bundleQty;
    const normalizedQty = [3, 5, 7].includes(qty) ? qty : 5;

    if (!window.allProducts || !Array.isArray(window.allProducts)) {
      return [];
    }

    const coffeeDatabase = window.allProducts.map((product) => ({
      ...product,
      prep_method: product.metafields.coffee_prep_methods || [],
      tastes: product.metafields.coffee_tastes || [],
    }));

    const text = userText.toLowerCase();
    const scores = coffeeDatabase.map((coffee) => {
      let score = 0;

      if (Array.isArray(coffee.prep_method)) {
        coffee.prep_method.forEach((method) => {
          if (text.includes(method.toLowerCase())) score += 3;
        });
      }

      if (Array.isArray(coffee.tastes)) {
        coffee.tastes.forEach((taste) => {
          if (text.includes(taste.toLowerCase())) score += 2;
        });
      }

      if (Array.isArray(coffee.prep_method)) {
        if (text.includes('אספרסו') || text.includes('חזק') || text.includes('עז')) {
          if (coffee.prep_method.includes('Espresso')) score += 2;
        }
        if (
          text.includes('חלב') ||
          text.includes('לאטה') ||
          text.includes("קפוצ'ינו") ||
          text.includes('קפוצינו') ||
          text.includes('קפה הפוך')
        ) {
          if (coffee.prep_method.includes('Espresso')) score += 2;
        }
        if (text.includes('פילטר') || text.includes('עדין') || text.includes('קל')) {
          if (coffee.prep_method.includes('Filter')) score += 2;
        }
        if (text.includes('מקינטה') || text.includes('מוקה')) {
          if (coffee.prep_method.includes('MokaPot')) score += 2;
        }
      }

      if (Array.isArray(coffee.tastes)) {
        if (text.includes('פירותי') || text.includes('בהיר') || text.includes('חמוץ') || text.includes('חמצמץ')) {
          if (coffee.tastes.includes('Fruity') || coffee.tastes.includes('Fruity-Sweet')) score += 2;
        }
        if (text.includes('מתוק') || text.includes('מתיקות')) {
          if (
            coffee.tastes.includes('Sweet') ||
            coffee.tastes.includes('Sweet-Chocolate') ||
            coffee.tastes.includes('Fruity-Sweet')
          )
            score += 2;
        }
        if (text.includes('שוקולד') || text.includes('קקאו')) {
          if (coffee.tastes.includes('Chocolate') || coffee.tastes.includes('Sweet-Chocolate')) score += 2;
        }
      }

      return { coffee, score };
    });

    const positiveScores = scores.filter((item) => item.score > 0).sort((a, b) => b.score - a.score);

    const vendorsWithMatches = [
      ...new Set(positiveScores.map(({ coffee }) => (coffee.vendor || '').trim().toLowerCase()).filter(Boolean)),
    ];

    if (
      !window.__questionnaireVendorByQty ||
      window.__questionnaireVendorAssignmentForText !== userText
    ) {
      window.__questionnaireVendorByQty = pickRandomVendorsPerBundleQty(vendorsWithMatches);
      window.__questionnaireVendorAssignmentForText = userText;
    }

    const targetVendor = (window.__questionnaireVendorByQty[normalizedQty] || '').toLowerCase();
    if (!targetVendor) {
      return [];
    }

    const forVendor = positiveScores.filter(({ coffee }) => {
      const v = (coffee.vendor || '').trim().toLowerCase();
      return v === targetVendor;
    });

    return forVendor
      .map((item) => item.coffee)
      .slice(0, 7);
  }

  function formatQuestionnaireBundleWeightKg(grams) {
    if (grams == null || grams <= 0) return '';
    var kg = grams / 1000;
    var s = kg.toFixed(3).replace(/\.?0+$/, '');
    return s + ' ק"ג';
  }

  function formatQuestionnaireProductWeight(grams) {
    if (grams == null || grams <= 0) return '—';
    if (grams >= 1000) return formatQuestionnaireBundleWeightKg(grams);
    return Math.round(grams) + ' גרם';
  }

  function updateQuestionnaireQtyOptionWeights() {
    var ut = window.__questionnaireMatchUserText;
    var wrapper = document.querySelector('.questionnaire-qty-selector-wrapper');
    if (!wrapper) return;
    wrapper.querySelectorAll('.qty-option').forEach(function (btn) {
      var wEl = btn.querySelector('.qty-option__weight');
      if (!wEl) return;
      var dq = btn.getAttribute('data-qty');
      var q = dq ? parseInt(dq, 10) : 0;
      if (!ut || typeof ut !== 'string' || !ut.length || !q) {
        wEl.textContent = '';
        return;
      }
      var prods = matchQuestionnaireCoffees(ut, q);
      var grams = 0;
      prods.slice(0, q).forEach(function (p) {
        grams += p.weight_grams || 0;
      });
      wEl.textContent = formatQuestionnaireBundleWeightKg(grams);
    });
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function normalizeMetaList(val) {
    if (val == null || val === '') return [];
    if (Array.isArray(val)) return val.filter(Boolean).map(String);
    if (typeof val === 'string') return [val];
    if (typeof val === 'object') {
      if (Array.isArray(val.value)) return val.value.map(String).filter(Boolean);
      if (val.value != null && val.value !== '') return [String(val.value)];
    }
    return [String(val)];
  }

  /** Matches snippets/product-taste-icon-color.liquid (carousel / bundle card overlay). */
  var Q_TASTE_PROFILE_BADGES = {
    Fruity: { className: 'fruity', label: 'פירותי' },
    Chocolate: { className: 'chocolate', label: 'שוקולדי' },
    'Sweet-Chocolate': { className: 'sweet-chocolate', label: 'מתוק שוקולדי' },
    Sweet: { className: 'sweet-balanced', label: 'מתוק מאוזן' },
    'Fruity-Sweet': { className: 'sweet-fruity', label: 'פירותי מתוק' },
  };

  function buildBundleTableTasteProfileIconsHtml(product) {
    if (!product) return '';
    var mf = product.metafields || {};
    var keys = normalizeMetaList(mf.coffee_taste);
    var parts = [];
    keys.forEach(function (raw) {
      var key = String(raw).trim();
      var spec = Q_TASTE_PROFILE_BADGES[key];
      if (!spec) return;
      parts.push(
        '<span class="' +
          spec.className +
          '">' +
          spec.label +
          '</span>'
      );
    });
    if (!parts.length) return '';
    return (
      '<div class="product-taste-icons questionnaire-product-taste-icons q-bundle-table__taste-icons">' +
      '<div class="selection-wrapper plp-taste-text-wrapper">' +
      parts.join('') +
      '</div></div>'
    );
  }

  function getBundleTableRoastDisplay(mf) {
    if (!mf) return '';
    var r = mf.coffee_roast_level;
    if (r == null || r === '') return '';
    if (typeof r === 'object' && r !== null && r.value != null && r.value !== '') {
      return String(r.value);
    }
    return String(r);
  }

  var _qBundleTableClickBound = false;

  function setupBundleTableRowActivation() {
    var tbody = document.getElementById('q-bundle-table-body');
    if (!tbody || _qBundleTableClickBound) return;
    _qBundleTableClickBound = true;
    tbody.addEventListener('click', function (e) {
      var row = e.target.closest('.q-bundle-table__row');
      if (!row) return;
      var pid = row.getAttribute('data-product-id');
      if (!pid) return;
      var pool = window.__qResultsShownProducts;
      var found =
        Array.isArray(pool) &&
        pool.find(function (p) {
          return p && String(p.id) === String(pid);
        });
      if (found) openQuestionnaireProductModal(found);
    });
  }

  function renderBundleTableFromProducts(shownProducts) {
    var tbody = document.getElementById('q-bundle-table-body');
    if (!tbody) return;
    window.__qResultsShownProducts = shownProducts;
    setupBundleTableRowActivation();
    if (!shownProducts || !shownProducts.length) {
      tbody.innerHTML =
        '<tr><td colspan="3" class="q-bundle-table__empty">אין מוצרים להצגה</td></tr>';
      return;
    }
    tbody.innerHTML = shownProducts
      .map(function (p) {
        var merged = mergeProductFromCatalog(p) || p;
        var title = escapeHtml((merged.title || '').trim() || '—');
        var imgUrl = merged.image ? escapeHtml(merged.image) : '';
        var thumb = imgUrl
          ? '<img class="q-bundle-table__thumb-img" src="' +
            imgUrl +
            '" alt="" loading="lazy" width="44" height="44">'
          : '<span class="q-bundle-table__thumb-fallback" aria-hidden="true"></span>';
        var mf = merged.metafields || {};
        var tasteIcons = buildBundleTableTasteProfileIconsHtml(merged);
        var tasteCell = tasteIcons || '—';
        var roastRaw = getBundleTableRoastDisplay(mf);
        var roastCell = roastRaw ? 'קלייה ' + escapeHtml(roastRaw) : '—';
        return (
          '<tr class="q-bundle-table__row" data-product-id="' +
          escapeHtml(String(merged.id)) +
          '">' +
          '<td class="q-bundle-table__td q-bundle-table__td--product"><div class="q-bundle-table__product">' +
          thumb +
          '<span class="q-bundle-table__title">' +
          title +
          '</span></div></td>' +
          '<td class="q-bundle-table__td q-bundle-table__td--taste">' +
          tasteCell +
          '</td>' +
          '<td class="q-bundle-table__td q-bundle-table__td--roast">' +
          roastCell +
          '</td>' +
          '</tr>'
        );
      })
      .join('');
  }

  function updateBundleToggleUi(isTable) {
    var sub = document.getElementById('q-bundle-view-toggle-sublabel');
    var btn = document.getElementById('q-bundle-view-toggle');
    var counter = document.getElementById('q-carousel-counter');
    if (sub) sub.textContent = isTable ? 'חזרה לתצוגת מארז' : 'הצג טבלה';
    if (btn) {
      btn.setAttribute('aria-expanded', isTable ? 'true' : 'false');
      btn.classList.toggle('is-table-active', isTable);
    }
    if (counter) counter.hidden = !!isTable;
  }

  function setupBundleViewToggle() {
    var btn = document.getElementById('q-bundle-view-toggle');
    var carouselView = document.getElementById('q-bundle-view-carousel');
    var tableView = document.getElementById('q-bundle-view-table');
    var step = document.getElementById('questionnaireResultsStep');
    if (!btn || !carouselView || !tableView || !step) return;
    if (btn._qBundleToggleBound) return;
    btn._qBundleToggleBound = true;
    btn.addEventListener('click', function () {
      var toTable = !step.classList.contains('results-step--table-view');
      step.classList.toggle('results-step--table-view', toTable);
      carouselView.hidden = toTable;
      tableView.hidden = !toTable;
      updateBundleToggleUi(toTable);
      if (!toTable) {
        window.dispatchEvent(new Event('resize'));
      }
    });
  }

  function resetBundleViewToCarousel() {
    var step = document.getElementById('questionnaireResultsStep');
    var carouselView = document.getElementById('q-bundle-view-carousel');
    var tableView = document.getElementById('q-bundle-view-table');
    if (!step || !carouselView || !tableView) return;
    step.classList.remove('results-step--table-view');
    carouselView.hidden = false;
    tableView.hidden = true;
    updateBundleToggleUi(false);
  }

  function mergeProductFromCatalog(product) {
    if (!product) return product;
    const catalog = window.allProducts;
    if (!Array.isArray(catalog)) return product;
    const full = catalog.find(function (p) {
      return String(p.id) === String(product.id);
    });
    /* Session/saved hits may omit fields; overlay catalog row so description/url/metafields resolve. */
    return full ? Object.assign({}, product, full) : product;
  }

