      </div>
    </div>

    <div class="questionnaire-footer-content">
      <div class="questionnaire-qty-selector-wrapper">
        <div class="questionnaire-qty-label">חבילות קפה במארז</div>
        <div
          class="questionnaire-qty-options"
          role="group"
          aria-label="חבילות קפה במארז">
          <button
            type="button"
            class="qty-option"
            data-qty="3">
            <span class="qty-option__stack">
              <span class="qty-option__num">3</span>
            {% comment %} <span class="qty-option__weight"></span> {% endcomment %}
            </span>
          </button>
          <button
            type="button"
            class="qty-option selected"
            data-qty="5">
            <span class="qty-option__stack">
              <span class="qty-option__num">5</span>
            {% comment %} <span class="qty-option__weight"></span> {% endcomment %}
            </span>
          </button>
