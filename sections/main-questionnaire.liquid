      <div class="questionnaire-btn-wrapper catalog-btn-wrapper">
        <button class="questionnaire-select-btn" onclick="window.location.href='/collections/all'">לכל הקטלוג</button>
      </div>
    </div>

    <div
      id="q-product-detail-modal"
      class="q-product-modal"
      hidden
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      aria-labelledby="q-product-modal-title">
      <div
        class="q-product-modal__backdrop"
        tabindex="-1"
        data-q-product-modal-close></div>
      <div class="q-product-modal__panel">
        <button
          type="button"
          class="q-product-modal__close"
          aria-label="סגירה"
          data-q-product-modal-close>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true">
            <path
              d="M6 6L18 18M18 6L6 18"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round" />
          </svg>
        </button>
        <div class="q-product-modal__body">
          <div class="q-product-modal__media">
            <img
              id="q-product-modal-image"
              class="q-product-modal__image"
              src=""
              alt=""
