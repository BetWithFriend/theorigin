      <div
        class="q-bundle-view q-bundle-view--table"
        id="q-bundle-view-table"
        hidden>
        <div
          class="q-bundle-table-scroll"
          role="region"
          aria-label="פירוט מוצרים במארז">
          <table class="q-bundle-table">
            <thead>
              <tr>
                <th scope="col">מוצר</th>
                <th scope="col">טעם</th>
                <th scope="col">רמת קלייה</th>
