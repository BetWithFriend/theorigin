{%- assign redirect_collection_url = section.settings.redirect_collection | default: '/collections/all' -%}
{%- assign close_redirect_url = section.settings.close_redirect | default: '/' -%}
{%- assign select_btn_text = section.settings.select_button_text | default: 'בחרו אפשרות' -%}
{%- assign continue_single_text = section.settings.continue_single_text | default: 'המשיכו עם בחירה אחת' -%}
<div>
  <div id="my-custom-results-area"></div>
</div>
<script>
  // Pass schema settings to JavaScript
  const questionnaireSettings = {
    redirectCollection: '{{ redirect_collection_url }}',
    closeRedirect: '{{ close_redirect_url }}',
    selectButtonText: '{{ select_btn_text }}',
    continueSingleText: '{{ continue_single_text }}',
    continueMultipleText: '{{ continue_multiple_js }}',
  };
  const QUESTIONNAIRE_RESULTS_STATE_KEY = 'questionnaireResultsState';
  let _qModalPreviousFocus = null;
  let _qRestartConfirmPreviousFocus = null;

  function getQuestionnaireBundleQtyFromDom() {
    const sel = document.querySelector('.questionnaire-qty-selector-wrapper .qty-option.selected');
    if (!sel) return 5;
    const dq = sel.getAttribute('data-qty');
    const n = dq ? parseInt(dq, 10) : parseInt(sel.textContent.trim(), 10);
    return [3, 5, 7].includes(n) ? n : 5;
  }

  /** Same as qty used for results footer / carousel bundle price. */
  function getQuestionnaireResultsBundleQty() {
    const sel = document.querySelector('.questionnaire-qty-selector-wrapper .qty-option.selected');
    if (!sel) return 1;
    const dq = sel.getAttribute('data-qty');
    if (dq) return parseInt(dq, 10) || 1;
    return parseInt(sel.textContent.trim(), 10) || 1;
  }

  /** Mirrors footer bundle: avg price per matched product × qty, with 3/5/7 pack discounts. */
  function bundleTotalCentsForQuestionnaireProducts(products, qty) {
    if (!Array.isArray(products) || !products.length) return 0;
    const n = products.length;
    let sumCents = 0;
    products.forEach(function (p) {
      sumCents += p.price_cents || 0;
    });
    const avgCents = sumCents / n;
    let totalCents = Math.round(avgCents * qty);
    if (qty === 5) {
      totalCents = Math.round(totalCents * 0.95);
    } else if (qty === 7) {
      totalCents = Math.round(totalCents * 0.9);
    }
    return totalCents;
  }

  function coffeesForVendorFromPositiveScores(positiveScores, vendorKeyLower) {
    const v = (vendorKeyLower || '').toLowerCase();
    if (!Array.isArray(positiveScores)) return [];
    return positiveScores
      .filter(function (item) {
        return item.coffee && (item.coffee.vendor || '').trim().toLowerCase() === v;
      })
      .map(function (item) {
        return item.coffee;
      })
      .slice(0, 7);
  }

  /* ——— QuestionnaireScoring engine ——— */
  (function (global) {
    const BUNDLE_SIZES = [3, 5, 7];

    const DEFAULT_WEIGHTS = {
      guidedPrepPerMatch: 1,
      guidedRoastPerMatch: 3,
      guidedTastePerMatch: 5,
    };

    const DEFAULT_MIN_BUNDLE_SCORE = { 3: 24, 5: 35, 7: 47 };

    const DEFAULT_THRESHOLDS = {
      minProductScore: 0,
      minBundleScore: { ...DEFAULT_MIN_BUNDLE_SCORE },
    };

    const HEBREW_TO_ENGLISH_PREP = {
      'מכונת אספרסו': 'Espresso',
      'משקאות חלב': 'Espresso',
      'קפה פילטר': 'Filter',
      'מקינטה': 'MokaPot',
    };

    const TASTE_CATEGORY_MAP = {
      'קלאסי':    ['Sweet', 'Sweet-Chocolate'],
      'מודרני':   ['Sweet', 'Fruity-Sweet'],
      'גל שלישי': ['Fruity', 'Fruity-Sweet'],
    };

    const ROAST_ORDER = ['בהירה', 'בהירה-בינונית', 'בינונית', 'בינונית-כהה', 'כהה'];

    function escapeRegExp(s) {
      return String(s).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function tasteMatches(coffeeTaste, selected) {
      return (
        coffeeTaste === selected ||
        (typeof coffeeTaste === 'string' &&
          typeof selected === 'string' &&
          (coffeeTaste.includes(selected) || selected.includes(coffeeTaste)))
      );
    }

    function tasteMatchMultiplier(coffeeTaste, selected) {
      if (coffeeTaste == null || selected == null) return 0;
      const ct = String(coffeeTaste).trim();
      const se = String(selected).trim();
      if (!ct || !se) return 0;
      if (ct === se) return 1;
      const esc = escapeRegExp(se);
      if (new RegExp('^' + esc + '(?:-|$)').test(ct)) return 0.65;
      if (new RegExp('-' + esc + '$').test(ct) || new RegExp('-' + esc + '-').test(ct)) return 0.4;
      if (tasteMatches(ct, se)) return 0.5;
      return 0;
    }

    function tasteBestForSelected(coffeeTastes, selectedTaste, w) {
      const base = w.guidedTastePerMatch;
      let best = { pts: 0, coffeeTaste: null };
      for (let i = 0; i < coffeeTastes.length; i++) {
        const ct = coffeeTastes[i];
        const mult = tasteMatchMultiplier(ct, selectedTaste);
        if (mult <= 0) continue;
        const pts = Math.round(base * mult * 10) / 10;
        if (pts > best.pts) best = { pts, coffeeTaste: ct };
      }
      return best;
    }

    function roastDistance(productRoast, selected) {
      const ip = ROAST_ORDER.indexOf(productRoast);
      const is = ROAST_ORDER.indexOf(selected);
      if (ip < 0 || is < 0) return -1;
      return Math.abs(ip - is);
