  <div class="questionnaire-icons-wrapper" id="questionnaireResultsStep">
    <header class="questionnaire-header questionnaire-header--results" role="banner">
      <div class="questionnaire-header__start">
        <div class="questionnaire-logo">
          <img
            src="{{ 'logo.png' | asset_url }}"
            alt="{{ shop.name }}"
            width="88"
            height="auto">
        </div>
      </div>
      <div class="questionnaire-header__center">
        <h1 class="results-title-main">
          המארז שלך
          <span class="results-title-counter" id="q-carousel-counter">(1/5)</span>
        </h1>
      </div>
      <div class="questionnaire-header__end">
        <button
          type="button"
          class="questionnaire-start-over"
          onclick="window.location.reload()">התחל חדש</button>
      </div>
    </header>

    <div class="q-carousel-container">
      <button
        class="q-carousel-arrow q-carousel-arrow--prev"
        id="qCarouselPrev"
        aria-label="הקודם"
        type="button">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg">
          <path
            d="M15 18L9 12L15 6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round" />
        </svg>
      </button>

      <div class="q-carousel-viewport" id="qCarouselViewport">
