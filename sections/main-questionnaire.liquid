  function normalizeMetaList(val) {
    if (val == null || val === '') return [];
    if (Array.isArray(val)) return val.filter(Boolean).map(String);
    if (typeof val === 'string') return [val];
    if (typeof val === 'object') {
      if (Array.isArray(val.value)) return val.value.map(String).filter(Boolean);
      if (val.value != null && val.value !== '') return [String(val.value)];
    }
    return [String(val)];
  }

  /** Matches snippets/product-taste-icon-color.liquid (carousel / bundle card overlay). */
  var Q_TASTE_PROFILE_BADGES = {
    Fruity: { className: 'fruity', label: 'פירותי' },
    Chocolate: { className: 'chocolate', label: 'שוקולדי' },
    'Sweet-Chocolate': { className: 'sweet-chocolate', label: 'מתוק שוקולדי' },
    Sweet: { className: 'sweet-balanced', label: 'מתוק מאוזן' },
    'Fruity-Sweet': { className: 'sweet-fruity', label: 'פירותי מתוק' },
  };

  function buildBundleTableTasteProfileIconsHtml(product) {
    if (!product) return '';
    var mf = product.metafields || {};
    var keys = normalizeMetaList(mf.coffee_taste);
    var parts = [];
    keys.forEach(function (raw) {
      var key = String(raw).trim();
      var spec = Q_TASTE_PROFILE_BADGES[key];
      if (!spec) return;
      parts.push(
        '<span class="' +
          spec.className +
          '">' +
          spec.label +
          '</span>'
      );
    });
    if (!parts.length) return '';
    return (
      '<div class="product-taste-icons questionnaire-product-taste-icons q-bundle-table__taste-icons">' +
      '<div class="selection-wrapper plp-taste-text-wrapper">' +
      parts.join('') +
      '</div></div>'
    );
  }

  function getBundleTableRoastDisplay(mf) {
    if (!mf) return '';
    var r = mf.coffee_roast_level;
    if (r == null || r === '') return '';
    if (typeof r === 'object' && r !== null && r.value != null && r.value !== '') {
      return String(r.value);
    }
    return String(r);
  }

