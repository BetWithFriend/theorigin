<script>
  (function () {
    var tnScript = document.querySelector('script[tnv-data-config]');
    if (tnScript) {
      var cfg = tnScript.getAttribute('tnv-data-config');
      tnScript.setAttribute('tnv-data-config', cfg.replace('"widgetLocation":"left"', '"widgetLocation":"right"'));
    }

    // TabNav button is in shadow DOM; poll a shallow walk instead of scanning every node on each mutation.
    function shiftTabNavButtonDown(root) {
      if (!root) return false;
      if (root.shadowRoot) {
        var btn = root.shadowRoot.querySelector('#tr-button-mobile');
        if (btn) {
          btn.style.transform = (btn.style.transform || '') + ' translateY(20px)';
          return true;
        }
      }
      var children = root.children;
      for (var i = 0; i < children.length; i++) {
        if (shiftTabNavButtonDown(children[i])) return true;
      }
      return false;
    }

    (function pollTabNavShift(attempt) {
      if (shiftTabNavButtonDown(document.body)) return;
      if (attempt < 40) setTimeout(function () { pollTabNavShift(attempt + 1); }, 250);
    })(0);
  })();
</script>

<div class="questionnaire-wrapper" id="questionnaireWrapperDesktop">
