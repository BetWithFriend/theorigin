{%- assign default_continue_multiple = 'המשיכו עם [count] בחירות' -%}
{%- assign continue_multiple_raw = section.settings.continue_multiple_text | default: default_continue_multiple -%}
{%- assign continue_multiple_js = continue_multiple_raw | replace: '[count]', '{count}' -%}
{%- assign redirect_collection_url = section.settings.redirect_collection | default: '/collections/all' -%}
{%- assign close_redirect_url = section.settings.close_redirect | default: '/' -%}
{%- assign select_btn_text = section.settings.select_button_text | default: 'בחרו אפשרות' -%}
{%- assign continue_single_text = section.settings.continue_single_text | default: 'המשיכו עם בחירה אחת' -%}
<div>
  <div id="my-custom-results-area"></div>
</div>
{% paginate collections.all.products by 1000 %}
  <script type="application/json" id="questionnaire-products-data">
    [
      {%- assign q_product_first = true -%}
      {% for product in collections.all.products %}
         {% unless product.tags contains 'bundle'
           or product.tags contains 'decaf'
           or product.tags contains 'Decaf'
           or product.metafields.custom.coffee_process == 'נטול קפאין'
           or product.metafields.custom.coffee_process == 'decaf'
           or product.metafields.custom.coffee_process == 'Decaf' %}
        {%- unless q_product_first -%},{%- endunless -%}{%- assign q_product_first = false -%}
        {%- liquid
          assign qv = product.selected_or_first_available_variant
          assign q_weight_g = qv.weight | times: 1
          case qv.weight_unit
            when 'kg'
              assign q_weight_g = qv.weight | times: 1000
            when 'lb'
              assign q_weight_g = qv.weight | times: 453.592
            when 'oz'
              assign q_weight_g = qv.weight | times: 28.3495
          endcase
          assign q_weight_g = q_weight_g | round
          if q_weight_g == 0
            assign q_title_weight = qv.title | split: ' ' | first | plus: 0
            if q_title_weight > 0
              assign q_weight_g = q_title_weight
            else
              unless product.tags contains 'no-weight'
                assign q_weight_g = 250
              endunless
            endif
          endif
          assign q_taste_labels = product.metafields.custom.coffee_tastes.value
        -%}
        {%- capture q_product_short_desc -%}{{ product.metafields.custom.short_description }}{%- endcapture -%}
        {
            "id": {{ product.id }},
            "title": {{ product.title | json }},
            "handle": {{ product.handle | json }},
            "vendor": {{ product.vendor | json }},
            "price": {{ product.price | money | json }},
            "price_cents": {{ product.price }},
            "weight_grams": {{ q_weight_g }},
            "compare_at_price_cents": {{ product.compare_at_price | default: 0 }},
            "variantId": {{ product.selected_or_first_available_variant.id }},
            "available": {{ product.selected_or_first_available_variant.available }},
            "image": {{ product.featured_image | image_url: width: 600 | json }},
            "short_description": {{ q_product_short_desc | strip | json }},
            "url": {{ product.url | json }},
            "metafields": {
              "coffee_roast_level": {{ product.metafields.custom.coffee_roast_level | json }},
              "coffee_prep_methods": {{ product.metafields.custom.coffee_prep_methods }},
              "coffee_tastes": {{ product.metafields.custom.coffee_tastes }},
              "coffee_taste": {{ product.metafields.custom.coffee_taste | json }},
              "vendor_short_name": {{ product.metafields.vendor_info.coffee_vendor.value.vendor_short_name | json }}
            },
            "taste_labels": {% if q_taste_labels %}{{ q_taste_labels | json }}{% else %}[]{% endif %}
        }
          {% endunless %}
      {% endfor %}
    ]
  </script>
{% endpaginate %}
<script>
  const questionnaireSettings = {
    redirectCollection: '{{ redirect_collection_url }}',
    closeRedirect: '{{ close_redirect_url }}',
    selectButtonText: '{{ select_btn_text }}',
    continueSingleText: '{{ continue_single_text }}',
    continueMultipleText: '{{ continue_multiple_js }}',
  };
  const QUESTIONNAIRE_RESULTS_STATE_KEY = 'questionnaireResultsState';
  const QUESTIONNAIRE_ORIGIN_KEY = 'questionnaireOriginUrl';
  let _qModalPreviousFocus = null;
  let _qRestartConfirmPreviousFocus = null;

  (function captureQuizOrigin() {
    if (sessionStorage.getItem(QUESTIONNAIRE_ORIGIN_KEY)) return;
    var ref = document.referrer;
    if (ref && ref.indexOf(window.location.origin) === 0) {
      var refPath = ref.replace(window.location.origin, '');
      if (refPath.indexOf('/pages/questionnaire') !== 0) {
        sessionStorage.setItem(QUESTIONNAIRE_ORIGIN_KEY, ref);
      }
    }
  })();

  function ensureAllProductsLoaded() {
    if (window.allProducts && Array.isArray(window.allProducts)) {
      return window.allProducts;
    }
    var el = document.getElementById('questionnaire-products-data');
    if (!el) {
      window.allProducts = [];
      return window.allProducts;
    }
    try {
      window.allProducts = JSON.parse(el.textContent);
    } catch (error) {
      console.error('Failed to parse questionnaire product catalog:', error);
      window.allProducts = [];
    }
    return window.allProducts;
  }

  function preloadAllProductsWhenIdle() {
    var run = function () { ensureAllProductsLoaded(); };
    if (typeof requestIdleCallback === 'function') {
      requestIdleCallback(run, { timeout: 3000 });
    } else {
      setTimeout(run, 200);
    }
  }

  function getQuestionnaireBundleQtyFromDom() {
    const sel = document.querySelector('.questionnaire-qty-selector-wrapper .qty-option.selected');
    if (!sel) return 5;
    const dq = sel.getAttribute('data-qty');
    const n = dq ? parseInt(dq, 10) : parseInt(sel.textContent.trim(), 10);
    return [3, 5, 7].includes(n) ? n : 5;
  }

  /** Same as qty used for results footer / carousel bundle price. */
  function getQuestionnaireResultsBundleQty() {
    const sel = document.querySelector('.questionnaire-qty-selector-wrapper .qty-option.selected');
    if (!sel) return 5;
    const dq = sel.getAttribute('data-qty');
    if (dq) {
      const n = parseInt(dq, 10);
      return [3, 5, 7].includes(n) ? n : 5;
    }
    const fallback = parseInt(sel.textContent.trim(), 10);
    return [3, 5, 7].includes(fallback) ? fallback : 5;
  }

  function trackQuestionnaireAnalyticsClick(buttonName, properties) {
    if (typeof analytics !== 'undefined' && analytics.trackClick) {
      analytics.trackClick(buttonName, properties);
    }
  }

  function trackQuestionnaireScreenView(screenName, properties) {
    if (typeof analytics !== 'undefined' && analytics.trackScreenView) {
      analytics.trackScreenView(screenName, properties);
    }
  }

  function getQuestionnaireVendorDisplayName(vendorKey) {
    const key = (vendorKey != null ? vendorKey : window.__questionnaireSelectedVendor || '').toLowerCase();
    const opts = window.__questionnaireVendorOptions;
    if (Array.isArray(opts)) {
      const opt = opts.find(function (o) {
        return (o.vendorKey || '').toLowerCase() === key;
      });
      if (opt) return opt.label || opt.vendorKey || key;
    }
    return key;
  }

  function getQuestionnaireBundlePurchaseProps(products) {
    const qty = getQuestionnaireResultsBundleQty();
    const prods = Array.isArray(products) ? products : [];
    return {
      'Bundle size': qty,
      'Bundle Vendor': getQuestionnaireVendorDisplayName(),
      'Bundle price': formatQuestionnaireMoney(bundleTotalWithShippingCentsForQuestionnaireProducts(prods, qty)),
    };
  }

  function getQuestionnaireQuizBackStepLabel(step) {
    if (step === 1) return 'Step 1';
    if (step === 2) return 'Step 2';
    if (step === 3) return 'Step 3';
    return null;
  }

  function getQuestionnaireSelectionTitle(item) {
    if (!item) return '';
    const titleEl = item.querySelector('.questionnaire-text');
    return titleEl ? titleEl.textContent.trim() : '';
  }

  function trackQuizResultsScreenViewOnce() {
    if (window.__questionnaireResultsScreenTracked) return;
    window.__questionnaireResultsScreenTracked = true;
    trackQuestionnaireScreenView('Quiz Results');
  }

  const QUESTIONNAIRE_LINE_PROP_BUNDLE = '_questionnaire_bundle';

  /** Per-vendor shipping (ILS) and free-shipping thresholds (cents); mirrors snippets/cart-drawer.liquid */
  const QUESTIONNAIRE_VENDOR_SHIPPING = {
    canopy: { shipping: 35, freeThresholdCents: 22500 },
    blooms: { shipping: 35, freeThresholdCents: 22000 },
    youneedcoffee: { shipping: 55, freeThresholdCents: 25000 },
    coffeeorg: { shipping: 35, freeThresholdCents: 25000 },
    coffeeculture: { shipping: 35, freeThresholdCents: 30000 },
    elijahscoffee: { shipping: 35, freeThresholdCents: 30000 },
    tostato: { shipping: 35, freeThresholdCents: 25000 },
    brewbrothers: { shipping: 35, freeThresholdCents: 30000 },
    uru: { shipping: 35, freeThresholdCents: 25000 },
  };

  // Vendors temporarily excluded from questionnaire bundle results.
  // Remove a vendor from this list to restore it.
  const TEMPORARILY_EXCLUDED_VENDORS = ['coffeeculture'];

  /** Mirrors footer bundle: avg price per matched product × qty (subtotal, no shipping). */
  function bundleTotalCentsForQuestionnaireProducts(products, qty) {
    if (!Array.isArray(products) || !products.length) return 0;
    const n = products.length;
