      </div>
      <div class="questionnaire-title">{{ section.settings.step1_title | default: 'איך אתם מכינים את הקפה' }}</div>
      <div class="questionnaire-back-icon-wrapper">
        {% comment %} <img class="questionnaire-back-icon" src="{{ 'questionnaire_back_icon.png' |  asset_url }}" alt="Close icon" onclick="closeForm()"/> {% endcomment %}
      </div>
    </div>

