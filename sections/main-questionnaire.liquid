{%- comment -%} Lazy load questionnaire CSS {%- endcomment -%}
<link
  rel="preload"
  href="{{ 'questionnaire.css' | asset_url }}"
  as="style"
  onload="this.onload=null;this.rel='stylesheet'">
<noscript>{{ 'questionnaire.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'template-collection.css' | asset_url | stylesheet_tag }}</noscript>
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>

<div class="questionnaire-wrapper" id="questionnaireWrapperDesktop">
  <script>
    (function () {
      var el = document.getElementById('questionnaireWrapperDesktop');
      if (!el) return;
      var nav = performance.getEntriesByType && performance.getEntriesByType('navigation')[0];
      var isReload = nav && nav.type === 'reload';
      if (!isReload && typeof performance !== 'undefined' && performance.navigation) {
        isReload = performance.navigation.type === 1;
      }
      if (isReload) el.classList.add('initializing');
    })();
  </script>
  <div class="questionnaire-loader-wrapper questionnaire-init-loader">
    <img
      class="questionnaire-loader-img"
      src="{{ 'questionnaire_loader.png'  |  asset_url}}"
      alt="">
    <div class="questionnaire-loader-text">
      {{ section.settings.loader_text | default: 'מתאימים את פולי הקפה בדיוק בשבילך' }}
    </div>
  </div>
  <div class="questionnaire-icons-wrapper active">
    {% paginate collections.all.products by 1000 %}
      <script>
        window.allProducts = [
          {% for product in collections.all.products %}
            {%- capture card_html -%}
            {% comment %} <li class="grid__item slider__slide grid-item-feed" id="Slide-{{ section.id }}-{{ product.id }}"> {% endcomment %}
              {% render 'questionnaire-product', card_product: product %}
            {% comment %} </li> {% endcomment %}
            {%- endcapture -%}
             {% unless product.tags contains 'bundle' %}
            {%- capture q_product_short_desc -%}{{ product.metafields.custom.short_description }}{%- endcapture -%}
            {
                "id": {{ product.id }},
                "title": {{ product.title | json }},
                "handle": {{ product.handle | json }},
                "vendor": {{ product.vendor | json }},
                "price": {{ product.price | money | json }},
                "price_cents": {{ product.price }},
                "compare_at_price_cents": {{ product.compare_at_price | default: 0 }},
                "variantId": {{ product.selected_or_first_available_variant.id }},
                "available": {{ product.selected_or_first_available_variant.available }},
                "image": {{ product.featured_image | image_url: width: 600 | json }},
                "short_description": {{ q_product_short_desc | strip | json }},
                "description": {{ product.description | strip_html | truncate: 4000 | json }},
                "description_html": {{ product.description | json }},
                "url": {{ product.url | json }},
                "metafields": {
                  "coffee_roast_level": {{ product.metafields.custom.coffee_roast_level | json }},
                  "coffee_prep_methods": {{ product.metafields.custom.coffee_prep_methods }},
                  "coffee_tastes": {{ product.metafields.custom.coffee_tastes }}
                },
                "html_card": {{ card_html | json }}
            },
              {% endunless %}
          {% endfor %}
        ];
      </script>
    {% endpaginate %}

    {% for product in collection.products %}
      <script>
        console.log('boom2', {{ product | json }});
      </script>
      <!-- Access product data here -->
      <h3>{{ product.title }}</h3>
      <p>{{ product.description }}</p>
    {% endfor %}

    <div class="questionnaire-title-wrapper">
      <div class="questionnaire-close-icon" onclick="closeForm()">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false">
