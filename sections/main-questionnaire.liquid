  function runQuestionnaireBootstrap() {
    const savedResultsProducts = loadResultsState();
    const questionnaireWrapper = document.getElementById('questionnaireWrapperDesktop');
    preloadAllProductsWhenIdle();

    if (savedResultsProducts) {
      setupResultsVendorSelect();
      renderQuestionnaireResults(savedResultsProducts);

      if (typeof window.__questionnaireMatchUserText === 'string' && window.__questionnaireMatchUserText.length) {
        const refreshVendorMeta = function () {
          matchQuestionnaireCoffees(window.__questionnaireMatchUserText);
          updateResultsVendorSelect();
        };
        if (typeof requestIdleCallback === 'function') {
          requestIdleCallback(refreshVendorMeta, { timeout: 2000 });
        } else {
          setTimeout(refreshVendorMeta, 0);
        }
      }
      return;
    }

    if (questionnaireWrapper) {
      questionnaireWrapper.classList.remove('initializing');
    }
  }

  runQuestionnaireBootstrap();

