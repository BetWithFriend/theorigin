            src="{{ 'payment-mastercard.webp' | asset_url }}"
            alt="Mastercard"
            width="24"
            height="16">
          <img
            src="{{ 'payment-google-pay.webp' | asset_url }}"
            alt="Google Pay"
            width="24"
            height="16">
          <img
            src="{{ 'payment-visa.webp' | asset_url }}"
            alt="Visa"
            width="24"
            height="16">
          <img
            src="{{ 'payment-apple-pay.webp' | asset_url }}"
            alt="Apple Pay"
            width="24"
            height="16">
          <img
            src="{{ 'payment-paypal.png' | asset_url }}"
            alt="PayPal"
            width="24"
            height="16">
          <img
            src="{{ 'payment-max.webp' | asset_url }}"
            alt="Max"
            width="24"
            height="16">
        </div>
        <div class="questionnaire-secure-icons">
          <img
            src="{{ 'secure_buy.png' | asset_url }}"
            alt="Secure Buy"
            width="16"
            height="16">
          <div class="secure-text">רכישה מאובטחת</div>
        </div>
