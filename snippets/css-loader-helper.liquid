{%- comment -%}
  CSS Loader Helper - Fallback for browsers that don't support CSS preload.
  Runs at DOMContentLoaded so all <link rel="preload"> elements exist.
{%- endcomment -%}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var supportsPreload = false;
    try {
      supportsPreload = document.createElement('link').relList.supports('preload');
    } catch (e) {}

    if (!supportsPreload) {
      document.querySelectorAll('link[rel="preload"][as="style"]').forEach(function (link) {
        link.setAttribute('rel', 'stylesheet');
        link.removeAttribute('onload');
      });
    }
  });
</script>
